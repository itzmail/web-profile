---
import Layout from "../../layouts/Layout.astro";
---

<Layout
    title="Certificates — Ismail Alam"
    description="Professional certificates and training credentials by Ismail Alam."
>
    <main class="certs-page">
        <div class="container">
            <nav class="breadcrumb">
                <a href="/" class="back-link font-mono">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 18l-6-6 6-6"/>
                    </svg>
                    Back to Home
                </a>
            </nav>

            <header class="page-header reveal">
                <p class="page-label font-mono">// credentials</p>
                <h1 class="page-title">Certificates <span>&amp; Training</span></h1>
                <p class="page-subtitle" id="cert-count">&nbsp;</p>
            </header>

            <div id="certs-loading" class="loading-state">
                <div class="skeleton-grid">
                    {Array.from({ length: 6 }).map(() => (
                        <div class="skeleton-card">
                            <div class="skeleton-line skeleton-line--short"></div>
                            <div class="skeleton-line skeleton-line--long"></div>
                            <div class="skeleton-line skeleton-line--medium"></div>
                        </div>
                    ))}
                </div>
            </div>

            <div id="certs-error" class="error-state" style="display:none;">
                <p class="font-mono text-muted">Failed to load certificates.</p>
            </div>

            <div id="certs-grid" class="certs-grid" style="display:none;"></div>
        </div>
    </main>

    <!-- Detail Modal -->
    <div id="cert-modal" class="modal-backdrop" aria-hidden="true">
        <div class="modal-box" role="dialog" aria-modal="true">
            <button class="modal-close font-mono" id="cert-modal-close" aria-label="Close">&times;</button>
            <div class="modal-body" id="cert-modal-body"></div>
        </div>
    </div>
</Layout>

<script>
    const API_BASE = import.meta.env.PUBLIC_API_URL ?? "https://my-data.itsmail.dev/api";

    interface CertData {
        id: string;
        title: string;
        description?: string;
        issuer?: string;
        issued_at?: string;
        expired_at?: string | null;
        credential_id?: string | null;
        credential_url?: string | null;
        category?: string | null;
        file_url?: string | null;
        file_type?: "pdf" | "image" | null;
    }

    interface ApiCertificate {
        id: string;
        title: string;
        description: string;
        is_active: number;
        order: number;
        web_profile: {
            data: {
                slug: string;
                issuer: string;
                issued_at: string;
                expired_at: string | null;
                credential_id: string | null;
                credential_url: string | null;
                category: string | null;
                file_url: string | null;
                file_type: "pdf" | "image" | null;
            };
        };
    }

    function formatDate(dateStr: string | null | undefined): string {
        if (!dateStr) return "";
        return new Date(dateStr).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
    }

    function formatDateShort(dateStr: string | null | undefined): string {
        if (!dateStr) return "";
        return new Date(dateStr).toLocaleDateString("en-US", { year: "numeric", month: "short" });
    }

    function isExpired(expiredAt: string | null | undefined): boolean {
        if (!expiredAt) return false;
        return new Date(expiredAt) < new Date();
    }

    function buildCardData(cert: ApiCertificate): CertData {
        const data = cert.web_profile?.data ?? {} as ApiCertificate["web_profile"]["data"];
        return {
            id: cert.id,
            title: cert.title,
            description: cert.description,
            ...data,
        };
    }

    function renderCard(cert: ApiCertificate): string {
        const data = cert.web_profile?.data ?? {} as ApiCertificate["web_profile"]["data"];
        const expired = isExpired(data.expired_at);
        const cardData = JSON.stringify(buildCardData(cert)).replace(/"/g, "&quot;");

        const badge = expired
            ? `<span class="cert-badge cert-badge--expired font-mono">expired</span>`
            : data.expired_at
                ? `<span class="cert-badge cert-badge--valid font-mono">valid</span>`
                : `<span class="cert-badge cert-badge--lifetime font-mono">lifetime</span>`;

        const categoryHtml = data.category
            ? `<span class="cert-category font-mono">${data.category}</span>`
            : `<span></span>`;

        const issuedHtml = data.issued_at
            ? `<span class="cert-date"><span class="date-label">issued</span>${formatDateShort(data.issued_at)}</span>`
            : "";

        const expiredHtml = data.expired_at
            ? `<span class="cert-date"><span class="date-label">expires</span>${formatDateShort(data.expired_at)}</span>`
            : "";

        const fileBadge = data.file_url
            ? `<span class="cert-file-badge font-mono">${data.file_type === "pdf" ? "PDF" : "IMG"}</span>`
            : "";

        const verifyHtml = data.credential_url
            ? `<span class="cert-verify font-mono">verify &rarr;</span>`
            : "";

        const descHtml = cert.description
            ? `<p class="cert-desc">${cert.description}</p>`
            : "";

        return `
            <button class="cert-card${expired ? " cert-card--expired" : ""}" data-cert="${cardData}" aria-label="View ${cert.title}">
                <div class="cert-card-header">${categoryHtml}${badge}</div>
                <h2 class="cert-title">${cert.title}</h2>
                ${data.issuer ? `<p class="cert-issuer font-mono"><span class="issuer-label">by</span> ${data.issuer}</p>` : ""}
                ${descHtml}
                <div class="cert-dates font-mono">${issuedHtml}${expiredHtml}</div>
                <div class="cert-card-footer">${fileBadge}${verifyHtml}</div>
            </button>
        `;
    }

    function renderModal(data: CertData): void {
        const body = document.getElementById("cert-modal-body");
        if (!body) return;

        const expired = isExpired(data.expired_at);

        const fileHtml = data.file_url
            ? data.file_type === "pdf"
                ? `<div class="modal-file-section">
                     <p class="modal-section-label font-mono">// certificate file</p>
                     <a href="${data.file_url}" target="_blank" rel="noopener noreferrer" class="modal-file-link font-mono">
                         <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                             <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                         </svg>
                         Download PDF
                     </a>
                   </div>`
                : `<div class="modal-file-section">
                     <p class="modal-section-label font-mono">// certificate</p>
                     <img src="${data.file_url}" alt="${data.title}" class="modal-cert-image" loading="lazy" />
                   </div>`
            : "";

        const verifyHtml = data.credential_url
            ? `<a href="${data.credential_url}" target="_blank" rel="noopener noreferrer" class="modal-verify-btn font-mono">Verify Credential &rarr;</a>`
            : "";

        const credentialIdHtml = data.credential_id
            ? `<div class="modal-meta-row">
                   <span class="modal-meta-label font-mono">Credential ID</span>
                   <span class="modal-meta-value font-mono">${data.credential_id}</span>
               </div>`
            : "";

        body.innerHTML = `
            <div class="modal-cert-header">
                <div class="modal-badges">
                    ${data.category ? `<span class="modal-badge modal-badge--category font-mono">${data.category}</span>` : ""}
                    ${expired
                        ? `<span class="modal-badge modal-badge--expired font-mono">expired</span>`
                        : data.expired_at
                            ? `<span class="modal-badge modal-badge--valid font-mono">valid</span>`
                            : `<span class="modal-badge modal-badge--lifetime font-mono">lifetime</span>`
                    }
                </div>
                <h2 class="modal-title">${data.title}</h2>
                ${data.issuer ? `<p class="modal-issuer font-mono">by ${data.issuer}</p>` : ""}
            </div>
            ${data.description ? `<p class="modal-description">${data.description}</p>` : ""}
            <div class="modal-meta">
                ${data.issued_at ? `<div class="modal-meta-row"><span class="modal-meta-label font-mono">Issued</span><span class="modal-meta-value font-mono">${formatDate(data.issued_at)}</span></div>` : ""}
                ${data.expired_at ? `<div class="modal-meta-row"><span class="modal-meta-label font-mono">Expires</span><span class="modal-meta-value font-mono${expired ? " text-expired" : ""}">${formatDate(data.expired_at)}</span></div>` : ""}
                ${credentialIdHtml}
            </div>
            ${fileHtml}
            ${verifyHtml}
        `;
    }

    const modal = document.getElementById("cert-modal") as HTMLElement;
    const closeBtn = document.getElementById("cert-modal-close") as HTMLElement;

    function openModal(data: CertData): void {
        renderModal(data);
        modal.setAttribute("aria-hidden", "false");
        modal.classList.add("active");
        document.body.style.overflow = "hidden";
    }

    function closeModal(): void {
        modal.setAttribute("aria-hidden", "true");
        modal.classList.remove("active");
        document.body.style.overflow = "";
    }

    function attachCardListeners(): void {
        document.querySelectorAll<HTMLButtonElement>(".cert-card").forEach((card) => {
            card.addEventListener("click", () => {
                const raw = card.dataset.cert;
                if (!raw) return;
                try {
                    openModal(JSON.parse(raw) as CertData);
                } catch {}
            });
        });
    }

    closeBtn.addEventListener("click", closeModal);
    modal.addEventListener("click", (e) => { if (e.target === modal) closeModal(); });
    document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeModal(); });

    // Fetch data client-side
    async function loadCertificates(): Promise<void> {
        const loading = document.getElementById("certs-loading")!;
        const errorEl = document.getElementById("certs-error")!;
        const grid = document.getElementById("certs-grid")!;
        const countEl = document.getElementById("cert-count")!;

        try {
            const res = await fetch(`${API_BASE}/certificates`);
            if (!res.ok) throw new Error(`HTTP ${res.status}`);
            const certs: ApiCertificate[] = await res.json();

            loading.style.display = "none";

            if (certs.length === 0) {
                countEl.textContent = "0 credentials";
                errorEl.innerHTML = `<p class="font-mono text-muted" style="font-size:0.875rem;">No certificates yet.</p>`;
                errorEl.style.display = "block";
                return;
            }

            countEl.textContent = `${certs.length} credential${certs.length !== 1 ? "s" : ""}`;
            grid.innerHTML = certs.map(renderCard).join("");
            grid.style.display = "grid";
            attachCardListeners();
        } catch {
            loading.style.display = "none";
            errorEl.style.display = "block";
        }
    }

    loadCertificates();
</script>

<style is:global>
    .certs-page {
        padding-top: calc(var(--nav-h) + 3rem);
        padding-bottom: 6rem;
    }

    .breadcrumb {
        margin-bottom: 2.5rem;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.8rem;
        color: var(--text-muted);
        text-decoration: none;
        transition: color var(--duration) var(--ease);
    }

    .back-link:hover {
        color: var(--green);
    }

    .page-header {
        margin-bottom: 3rem;
    }

    .page-label {
        font-size: 0.65rem;
        color: var(--text-muted);
        letter-spacing: 0.1em;
        margin-bottom: 0.5rem;
    }

    .page-title {
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 700;
        line-height: 1.1;
        margin-bottom: 0.5rem;
    }

    .page-title span {
        color: var(--green);
    }

    .page-subtitle {
        font-size: 0.875rem;
        color: var(--text-muted);
    }

    /* Skeleton */
    .skeleton-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1.25rem;
    }

    .skeleton-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        height: 180px;
    }

    .skeleton-line {
        background: linear-gradient(90deg, var(--border) 25%, rgba(255,255,255,0.04) 50%, var(--border) 75%);
        background-size: 200% 100%;
        animation: shimmer 1.5s infinite;
        border-radius: 4px;
        height: 12px;
    }

    .skeleton-line--short { width: 40%; }
    .skeleton-line--medium { width: 60%; }
    .skeleton-line--long { width: 85%; height: 18px; }

    @keyframes shimmer {
        0% { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }

    .error-state {
        text-align: center;
        padding: 3rem 0;
    }

    .certs-grid {
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1.25rem;
    }

    .cert-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        cursor: pointer;
        text-align: left;
        color: inherit;
        transition: border-color 0.3s var(--ease), transform 0.3s var(--ease), box-shadow 0.3s var(--ease);
        position: relative;
        overflow: hidden;
    }

    .cert-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at top right, rgba(0, 255, 136, 0.05), transparent 60%);
        opacity: 0;
        transition: opacity 0.35s var(--ease);
    }

    .cert-card:hover {
        border-color: var(--border-glow);
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.35), 0 0 20px var(--green-glow);
    }

    .cert-card:hover::before { opacity: 1; }

    .cert-card--expired { opacity: 0.65; }
    .cert-card--expired:hover { opacity: 1; }

    .cert-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
    }

    .cert-category {
        font-size: 0.65rem;
        color: var(--text-muted);
        letter-spacing: 0.08em;
    }

    .cert-badge {
        font-size: 0.6rem;
        padding: 0.15rem 0.5rem;
        border-radius: 4px;
        letter-spacing: 0.05em;
        border: 1px solid;
    }

    .cert-badge--valid {
        color: var(--green);
        border-color: rgba(0, 255, 136, 0.3);
        background: rgba(0, 255, 136, 0.06);
    }

    .cert-badge--lifetime {
        color: var(--cyan, #00d4ff);
        border-color: rgba(0, 212, 255, 0.3);
        background: rgba(0, 212, 255, 0.06);
    }

    .cert-badge--expired {
        color: rgba(255, 140, 100, 0.9);
        border-color: rgba(255, 100, 80, 0.25);
        background: rgba(255, 100, 80, 0.06);
    }

    .cert-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--text);
        line-height: 1.3;
        margin: 0;
    }

    .cert-issuer {
        font-size: 0.75rem;
        color: var(--text-muted);
        margin: 0;
    }

    .issuer-label { opacity: 0.5; }

    .cert-desc {
        font-size: 0.82rem;
        color: var(--text-muted);
        line-height: 1.6;
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .cert-dates {
        display: flex;
        gap: 1.25rem;
        margin-top: auto;
    }

    .cert-date {
        display: flex;
        flex-direction: column;
        font-size: 0.7rem;
    }

    .date-label {
        font-size: 0.6rem;
        color: var(--text-muted);
        opacity: 0.6;
        letter-spacing: 0.08em;
        margin-bottom: 0.1rem;
    }

    .cert-card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 0.25rem;
    }

    .cert-file-badge {
        font-size: 0.6rem;
        padding: 0.1rem 0.4rem;
        border: 1px solid var(--border);
        border-radius: 3px;
        color: var(--text-muted);
        letter-spacing: 0.05em;
    }

    .cert-verify {
        font-size: 0.7rem;
        color: var(--green);
        letter-spacing: 0.04em;
        margin-left: auto;
    }

    /* Modal */
    .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.75);
        backdrop-filter: blur(6px);
        z-index: 200;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.25s var(--ease);
    }

    .modal-backdrop.active {
        opacity: 1;
        pointer-events: all;
    }

    .modal-box {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 2rem;
        max-width: 560px;
        width: 100%;
        max-height: 85vh;
        overflow-y: auto;
        position: relative;
        transform: translateY(16px);
        transition: transform 0.25s var(--ease);
        scrollbar-width: thin;
        scrollbar-color: var(--border) transparent;
    }

    .modal-backdrop.active .modal-box {
        transform: translateY(0);
    }

    .modal-close {
        position: absolute;
        top: 1.25rem;
        right: 1.25rem;
        background: none;
        border: 1px solid var(--border);
        color: var(--text-muted);
        border-radius: 6px;
        width: 2rem;
        height: 2rem;
        font-size: 1.1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: color var(--duration) var(--ease), border-color var(--duration) var(--ease);
    }

    .modal-close:hover {
        color: var(--text);
        border-color: var(--text-muted);
    }

    :global(.modal-body) {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    :global(.modal-cert-header) {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    :global(.modal-badges) {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    :global(.modal-badge) {
        font-size: 0.6rem;
        padding: 0.15rem 0.5rem;
        border-radius: 4px;
        letter-spacing: 0.05em;
        border: 1px solid;
    }

    :global(.modal-badge--category) {
        color: var(--text-muted);
        border-color: var(--border);
        background: rgba(255, 255, 255, 0.04);
    }

    :global(.modal-badge--valid) {
        color: var(--green);
        border-color: rgba(0, 255, 136, 0.3);
        background: rgba(0, 255, 136, 0.06);
    }

    :global(.modal-badge--lifetime) {
        color: var(--cyan, #00d4ff);
        border-color: rgba(0, 212, 255, 0.3);
        background: rgba(0, 212, 255, 0.06);
    }

    :global(.modal-badge--expired) {
        color: rgba(255, 140, 100, 0.9);
        border-color: rgba(255, 100, 80, 0.25);
        background: rgba(255, 100, 80, 0.06);
    }

    :global(.modal-title) {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text);
        line-height: 1.2;
        margin: 0;
    }

    :global(.modal-issuer) {
        font-size: 0.8rem;
        color: var(--text-muted);
        margin: 0;
    }

    :global(.modal-description) {
        font-size: 0.9rem;
        color: var(--text-muted);
        line-height: 1.7;
        margin: 0;
    }

    :global(.modal-meta) {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        padding: 1rem;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--border);
        border-radius: 10px;
    }

    :global(.modal-meta-row) {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.78rem;
    }

    :global(.modal-meta-label) {
        color: var(--text-muted);
        font-size: 0.7rem;
    }

    :global(.modal-meta-value) { color: var(--text); }

    :global(.text-expired) { color: rgba(255, 140, 100, 0.85) !important; }

    :global(.modal-file-section) {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    :global(.modal-section-label) {
        font-size: 0.65rem;
        color: var(--text-muted);
        letter-spacing: 0.1em;
        margin: 0;
    }

    :global(.modal-cert-image) {
        width: 100%;
        border-radius: 10px;
        border: 1px solid var(--border);
        display: block;
    }

    :global(.modal-file-link) {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.82rem;
        color: var(--green);
        text-decoration: none;
        border: 1px solid rgba(0, 255, 136, 0.25);
        border-radius: 8px;
        padding: 0.6rem 1rem;
        transition: background var(--duration) var(--ease);
    }

    :global(.modal-file-link:hover) { background: rgba(0, 255, 136, 0.06); }

    :global(.modal-verify-btn) {
        display: inline-block;
        font-size: 0.82rem;
        color: var(--green);
        text-decoration: none;
        border: 1px solid rgba(0, 255, 136, 0.25);
        border-radius: 8px;
        padding: 0.6rem 1.25rem;
        text-align: center;
        transition: background var(--duration) var(--ease);
        cursor: pointer;
    }

    :global(.modal-verify-btn:hover) { background: rgba(0, 255, 136, 0.08); }

    @media (max-width: 768px) {
        .skeleton-grid,
        .certs-grid {
            grid-template-columns: 1fr;
        }

        .modal-box {
            padding: 1.5rem;
            max-height: 90vh;
        }
    }
</style>
