---
import { marked } from "marked";
import { apiFetch } from "../../utils/api";
import Layout from "../../layouts/Layout.astro";
import type { ApiProject } from "../../types/index";

export async function getStaticPaths() {
    const projects = await apiFetch<ApiProject[]>("/projects");
    if (!projects) return [];

    return projects.map((p) => ({
        params: { slug: p.web_profile?.data?.slug ?? p.id },
        props: { project: p },
    }));
}

interface Props {
    project: ApiProject;
}

const { project } = Astro.props;
const data = project.web_profile?.data;
const slug = data?.slug ?? "";
const accent = data?.accent ?? "#00ff88";
const stack = data?.stack ?? [];
const images = data?.images ?? [];
const links = data?.links ?? [];
const rawContent = data?.content ?? "";
const htmlContent = rawContent ? marked(rawContent) : "";

const linkIcons: Record<string, string> = {
    github: "M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z",
    gitlab: "M22.288 9.594l-.23-.599L19.392 1.2a.636.636 0 00-.61-.439.634.634 0 00-.61.44l-2.341 7.2H8.169L5.829 1.2A.635.635 0 005.219.762a.636.636 0 00-.611.44L1.942 8.993l-.229.6A4.524 4.524 0 003.43 14.66L10.44 20l3.559 2.694 2.168 1.639a.732.732 0 00.888 0l2.168-1.64L22.233 20l7.011-5.339a4.524 4.524 0 001.718-5.067",
    live: "M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14",
    playstore: "M3.18 23.76c.35.2.77.2 1.14-.02l12.4-7.17-3.08-3.08-10.46 10.27zM.58 1.52C.22 1.84 0 2.36 0 3.04v17.92c0 .68.22 1.2.58 1.52l.08.08 10.03-10.03v-.24L.66 1.44l-.08.08zM20.44 10.4l-2.85-1.65-3.37 3.37 3.37 3.37 2.87-1.66c.82-.47.82-1.24-.02-1.43zM4.32.26L16.72 7.4l-3.08 3.08L3.18.21C3.55-.01 3.97-.01 4.32.26z",
    appstore: "M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm-1.177 14.58L7.6 13.35l1.415-1.415 1.808 1.808 4.95-4.95 1.415 1.414-6.365 6.373z",
    youtube: "M19.59 6.69a4.83 4.83 0 01-3.77-2.75 12.65 12.65 0 00-8.45 0A4.83 4.83 0 013.6 6.69 49.17 49.17 0 002 12a49.17 49.17 0 001.6 5.31 4.83 4.83 0 003.77 2.75 12.65 12.65 0 008.45 0 4.83 4.83 0 003.77-2.75A49.17 49.17 0 0022 12a49.17 49.17 0 00-2.41-5.31zM10 15V9l5 3-5 3z",
};
---

<Layout
    title={`${project.title} — Ismail Alam`}
    description={project.description}
>
    <main class="project-detail">
        <div class="container">
            <nav class="breadcrumb">
                <a href="/#projects" class="back-link font-mono">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 18l-6-6 6-6"/>
                    </svg>
                    Back to Projects
                </a>
            </nav>

            <header class="project-header reveal">
                <div class="project-meta">
                    <p class="project-slug font-mono text-muted">{slug}.ts</p>
                    <h1 class="project-title" style={`--accent: ${accent}`}>{project.title}</h1>
                    {project.description && (
                        <p class="project-description">{project.description}</p>
                    )}
                </div>

                <div class="project-sidebar">
                    {stack.length > 0 && (
                        <div class="sidebar-block">
                            <h3 class="sidebar-label font-mono">// tech stack</h3>
                            <div class="tag-list">
                                {stack.map((tag) => (
                                    <span class="tag" style={`border-color: ${accent}33; color: ${accent}`}>{tag}</span>
                                ))}
                            </div>
                        </div>
                    )}

                    {links.length > 0 && (
                        <div class="sidebar-block">
                            <h3 class="sidebar-label font-mono">// links</h3>
                            <div class="links-list">
                                {links.map((link) => {
                                    const iconPath = linkIcons[link.label.toLowerCase()] ?? linkIcons.live;
                                    return (
                                        <a
                                            href={link.url}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="link-item"
                                            style={`--accent: ${accent}`}
                                        >
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                                <path d={iconPath} />
                                            </svg>
                                            <span class="font-mono">{link.label}</span>
                                        </a>
                                    );
                                })}
                            </div>
                        </div>
                    )}
                </div>
            </header>

            {images.length > 0 && (
                <div class="image-gallery reveal">
                    <div class="gallery-scroll">
                        {images.map((src, i) => (
                            <div class="gallery-item">
                                <img
                                    src={src}
                                    alt={`${project.title} screenshot ${i + 1}`}
                                    loading={i === 0 ? "eager" : "lazy"}
                                />
                            </div>
                        ))}
                    </div>
                    {images.length > 1 && (
                        <p class="gallery-hint font-mono text-muted">scroll &rarr; to see more</p>
                    )}
                </div>
            )}

            {htmlContent && (
                <article class="project-content reveal" set:html={htmlContent} />
            )}
        </div>
    </main>
</Layout>

<style>
    .project-detail {
        padding-top: calc(var(--nav-h) + 3rem);
        padding-bottom: 6rem;
    }

    .breadcrumb {
        margin-bottom: 2.5rem;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.8rem;
        color: var(--text-muted);
        text-decoration: none;
        transition: color var(--duration) var(--ease);
    }

    .back-link:hover {
        color: var(--green);
    }

    .project-header {
        display: grid;
        grid-template-columns: 1fr 260px;
        gap: 3rem;
        margin-bottom: 3rem;
        align-items: start;
    }

    .project-slug {
        font-size: 0.75rem;
        margin-bottom: 0.5rem;
    }

    .project-title {
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 700;
        color: var(--text);
        line-height: 1.1;
        margin-bottom: 1rem;
    }

    .project-description {
        font-size: 1rem;
        color: var(--text-muted);
        line-height: 1.7;
        max-width: 65ch;
    }

    .sidebar-block {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.25rem;
        margin-bottom: 1rem;
    }

    .sidebar-label {
        font-size: 0.65rem;
        color: var(--text-muted);
        letter-spacing: 0.1em;
        margin-bottom: 0.75rem;
        font-weight: 400;
    }

    .tag-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
    }

    .tag {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 4px;
        padding: 0.2rem 0.625rem;
    }

    .links-list {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .link-item {
        display: flex;
        align-items: center;
        gap: 0.625rem;
        padding: 0.6rem 0.875rem;
        border-radius: 8px;
        border: 1px solid var(--border);
        font-size: 0.8rem;
        color: var(--text-muted);
        text-decoration: none;
        text-transform: capitalize;
        transition: all var(--duration) var(--ease);
    }

    .link-item:hover {
        color: var(--accent);
        border-color: var(--accent);
        background: rgba(0, 0, 0, 0.2);
    }

    .image-gallery {
        margin-bottom: 3rem;
    }

    .gallery-scroll {
        display: flex;
        gap: 1rem;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        padding-bottom: 0.75rem;
        scrollbar-width: thin;
        scrollbar-color: var(--surface-border) transparent;
    }

    .gallery-scroll::-webkit-scrollbar {
        height: 4px;
    }

    .gallery-scroll::-webkit-scrollbar-thumb {
        background: var(--surface-border);
        border-radius: 2px;
    }

    .gallery-item {
        flex: 0 0 auto;
        scroll-snap-align: start;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid var(--border);
        max-height: 480px;
    }

    .gallery-item img {
        height: 100%;
        width: auto;
        max-width: 800px;
        display: block;
        object-fit: cover;
    }

    .gallery-hint {
        font-size: 0.7rem;
        margin-top: 0.5rem;
        text-align: right;
    }

    .project-content {
        max-width: 72ch;
        line-height: 1.8;
        color: var(--text-muted);
    }

    .project-content :global(h1),
    .project-content :global(h2),
    .project-content :global(h3),
    .project-content :global(h4) {
        color: var(--text);
        margin-top: 2rem;
        margin-bottom: 0.75rem;
    }

    .project-content :global(h2) {
        font-size: 1.375rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--border);
    }

    .project-content :global(h3) {
        font-size: 1.1rem;
    }

    .project-content :global(p) {
        margin-bottom: 1rem;
    }

    .project-content :global(ul),
    .project-content :global(ol) {
        margin-bottom: 1rem;
        padding-left: 1.5rem;
    }

    .project-content :global(li) {
        margin-bottom: 0.4rem;
    }

    .project-content :global(code) {
        font-family: var(--font-mono);
        font-size: 0.85em;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 0.1em 0.4em;
        color: var(--green);
    }

    .project-content :global(pre) {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 1.25rem;
        overflow-x: auto;
        margin-bottom: 1rem;
    }

    .project-content :global(pre code) {
        background: none;
        border: none;
        padding: 0;
        font-size: 0.875rem;
    }

    .project-content :global(a) {
        color: var(--green);
        text-decoration: underline;
        text-decoration-color: rgba(0, 255, 136, 0.3);
    }

    .project-content :global(a:hover) {
        text-decoration-color: var(--green);
    }

    .project-content :global(blockquote) {
        border-left: 3px solid var(--green);
        padding-left: 1rem;
        margin: 1rem 0;
        color: var(--text-dim);
        font-style: italic;
    }

    .project-content :global(hr) {
        border: none;
        border-top: 1px solid var(--border);
        margin: 2rem 0;
    }

    @media (max-width: 768px) {
        .project-header {
            grid-template-columns: 1fr;
        }

        .project-sidebar {
            order: -1;
        }

        .gallery-item img {
            max-width: 85vw;
        }
    }
</style>
