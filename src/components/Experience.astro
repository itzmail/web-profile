---
const contributions = [
    {
        icon: "🏢",
        role: "Fullstack Developer at Pintro",
        desc: "Developed and maintained high-performance web and mobile applications using Next JS, Flutter, and Golang.",
        accent: "--cyan",
    },
    {
        icon: "💻",
        role: "Software Engineer at PT Kuantum Solusi Teknologi",
        desc: "Engineered mobile apps with React Native/Flutter and developed REST APIs using Express.js and Spring Boot.",
        accent: "--green",
    },
    {
        icon: "📱",
        role: "Mobile Developer at CV Mutif Corporation",
        desc: "Maintained HRIS mobile app, developed a Warehouse Management System, and built Sales and Job Application platforms.",
        accent: "--purple",
    },
];
---

<section class="section" id="experience">
    <div class="container">
        <div class="section-header reveal">
            <p class="section-label">career journey</p>
            <h2 class="section-title">
                Work <span>Experience</span>
            </h2>
        </div>

        <div class="exp-grid">
            {
                contributions.map((c) => (
                    <div
                        class="exp-card reveal"
                        style={`--accent: var(${c.accent})`}
                    >
                        <div class="exp-icon">{c.icon}</div>
                        <div>
                            <h3 class="exp-role">{c.role}</h3>
                            <p class="exp-desc">{c.desc}</p>
                        </div>
                        <div class="exp-line" />
                    </div>
                ))
            }
        </div>

        <!-- Timeline philosophy -->
        <div class="philosophy reveal">
            <div class="philosophy-inner">
                <span class="phi-label font-mono text-green">// philosophy</span
                >
                <blockquote class="phi-quote">
                    "Good software is not just about making things work. It's
                    about making them <em>maintainable</em>, <em>readable</em>,
                    and <em>delightful</em> to use."
                </blockquote>
                <cite class="phi-cite font-mono text-muted">— Ismail Alam</cite>
            </div>
        </div>
    </div>
</section>

<style>
    .exp-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.25rem;
        margin-bottom: 3rem;
    }

    .exp-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.75rem;
        display: flex;
        flex-direction: column;
        gap: 0.875rem;
        position: relative;
        overflow: hidden;
        transition: all 0.3s var(--ease);
    }

    .exp-card:hover {
        border-color: var(--accent);
        transform: translateY(-4px);
        box-shadow: 0 16px 40px rgba(0, 0, 0, 0.4);
    }

    .exp-line {
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 3px;
        background: linear-gradient(to bottom, var(--accent), transparent);
        opacity: 0;
        transition: opacity 0.3s var(--ease);
    }

    .exp-card:hover .exp-line {
        opacity: 1;
    }

    .exp-icon {
        font-size: 1.75rem;
        line-height: 1;
    }

    .exp-role {
        font-size: 1rem;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 0.375rem;
    }

    .exp-desc {
        font-size: 0.875rem;
        color: var(--text-muted);
        line-height: 1.6;
    }

    /* Philosophy block */
    .philosophy {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 2.5rem;
        text-align: center;
        position: relative;
    }

    .philosophy-inner {
        max-width: 640px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .phi-label {
        font-size: 0.7rem;
        letter-spacing: 0.15em;
    }

    .phi-quote {
        font-size: clamp(1rem, 2vw, 1.25rem);
        color: var(--text);
        line-height: 1.7;
        font-style: italic;
        border: none;
        padding: 0;
    }

    .phi-quote em {
        color: var(--green);
        font-style: normal;
    }

    .phi-cite {
        font-size: 0.75rem;
    }
</style>
