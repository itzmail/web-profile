---
import MailIcon from "../assets/icons/MailIcon.astro";
import ExternalLinkIcon from "../assets/icons/ExternalLinkIcon.astro";
import { siteInfo, contactData, footerData } from "../data/site";
import { apiFetch } from "../utils/api";
import type { ApiSocial, Social } from "../types/index";

const apiSocials = await apiFetch<ApiSocial[]>("/socials");

const socials: Social[] = apiSocials
    ? apiSocials.map((s) => ({
          name: s.title,
          user: s.web_profile.data.user,
          href: s.web_profile.data.href,
          iconUrl: s.web_profile.data.icon_url,
      }))
    : [];
---

<section class="section" id="contact">
    <div class="container">
        <div class="contact-card reveal">
            <div class="contact-bg-text" aria-hidden="true">CONTACT</div>

            <div class="contact-inner">
                <div class="contact-left">
                    <p class="section-label">{contactData.collaborateText}</p>
                    <h2 class="contact-title">
                        {contactData.titleStart}<br /><span class="text-green"
                            >{contactData.titleHighlight}</span
                        >
                        {contactData.titleEnd}
                    </h2>
                    <p class="contact-desc">
                        {contactData.description}
                    </p>
                    <a
                        href={`mailto:${siteInfo.email}`}
                        class="btn btn-primary contact-cta"
                    >
                        <MailIcon width="16" height="16" />
                        {contactData.ctaText}
                    </a>
                </div>

                <div class="contact-right">
                    <p class="socials-label font-mono text-muted">
                        {contactData.socialsLabel}
                    </p>
                    <div class="socials-list">
                        {
                            socials.map((s) => (
                                    <a
                                        href={s.href}
                                        class="social-item"
                                        target="_blank"
                                        rel="noopener noreferrer"
                                    >
                                        <img
                                            src={s.iconUrl}
                                            class="social-icon"
                                            width="20"
                                            height="20"
                                            alt={s.name}
                                        />
                                        <div>
                                            <span class="social-name">
                                                {s.name}
                                            </span>
                                            <span class="social-user font-mono text-muted">
                                                {s.user}
                                            </span>
                                        </div>
                                        <ExternalLinkIcon
                                            class="social-arrow"
                                            width="14"
                                            height="14"
                                        />
                                    </a>
                            ))
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<footer class="footer">
    <div class="container footer-inner">
        <span class="font-mono text-muted footer-logo">
            <span class="text-green">{footerData.logoBracketLeft}</span>{
                footerData.logoName
            }<span class="text-cyan">{footerData.logoDot}</span>{
                footerData.logoDomain
            }<span class="text-green">{footerData.logoBracketRight}</span>
        </span>
        <p class="footer-copy font-mono text-muted">
            © {new Date().getFullYear()} {footerData.author}. All rights reserved.
        </p>
    </div>
</footer>

<style>
    /* ── Contact Card ─────────────────────────────────── */
    .contact-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: clamp(2rem, 5vw, 4rem);
        position: relative;
        overflow: hidden;
    }

    .contact-bg-text {
        position: absolute;
        right: -2rem;
        bottom: -1rem;
        font-size: clamp(6rem, 12vw, 10rem);
        font-weight: 900;
        color: rgba(255, 255, 255, 0.025);
        letter-spacing: -0.05em;
        user-select: none;
        pointer-events: none;
        line-height: 1;
    }

    .contact-inner {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
        position: relative;
        z-index: 1;
    }

    .contact-title {
        font-size: clamp(1.75rem, 3.5vw, 2.75rem);
        line-height: 1.15;
        margin: 0.5rem 0 1rem;
    }

    .contact-desc {
        font-size: 0.9375rem;
        color: var(--text-muted);
        line-height: 1.7;
        margin-bottom: 2rem;
        max-width: 420px;
    }

    .contact-cta {
        font-size: 0.875rem;
    }

    /* ── Socials ──────────────────────────────────────── */
    .socials-label {
        font-size: 0.7rem;
        letter-spacing: 0.15em;
        margin-bottom: 1.125rem;
    }

    .socials-list {
        display: flex;
        flex-direction: column;
        gap: 0.625rem;
    }

    .social-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.875rem 1rem;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--border);
        border-radius: 10px;
        text-decoration: none;
        transition: all var(--duration) var(--ease);
    }

    .social-item:hover {
        border-color: var(--border-glow);
        background: var(--green-glow);
        transform: translateX(4px);
    }

    .social-icon {
        color: var(--text-muted);
        display: flex;
        align-items: center;
        transition: color var(--duration) var(--ease);
    }

    .social-item:hover .social-icon {
        color: var(--green);
    }

    .social-name {
        display: block;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--text);
    }

    .social-user {
        font-size: 0.7rem;
    }

    .social-arrow {
        margin-left: auto;
        color: var(--text-dim);
        transition: all var(--duration) var(--ease);
    }

    .social-item:hover .social-arrow {
        color: var(--green);
        transform: translate(2px, -2px);
    }

    /* ── Footer ───────────────────────────────────────── */
    .footer {
        border-top: 1px solid var(--border);
        padding: 1.5rem 0;
        position: relative;
        z-index: 1;
    }

    .footer-inner {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .footer-logo {
        font-size: 0.875rem;
    }

    .footer-copy {
        font-size: 0.75rem;
        margin-left: auto;
    }

    .footer-links {
        display: flex;
        gap: 1rem;
    }

    .footer-link {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--text-muted);
        transition: color var(--duration) var(--ease);
    }

    .footer-link:hover {
        color: var(--green);
    }

    /* Responsive */
    @media (max-width: 768px) {
        .contact-inner {
            grid-template-columns: 1fr;
            gap: 2.5rem;
        }
        .footer-inner {
            flex-direction: column;
            text-align: center;
            gap: 1rem;
        }
        .footer-copy {
            margin-left: 0;
        }
    }
</style>
