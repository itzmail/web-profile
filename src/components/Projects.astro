---
import { apiFetch } from "../utils/api";
import type { ApiProject } from "../types/index";

const apiProjects = await apiFetch<ApiProject[]>("/projects");
const projects = apiProjects ?? [];
---

<section class="section" id="projects">
    <div class="container">
        <div class="section-header reveal">
            <p class="section-label">portfolio</p>
            <h2 class="section-title">Selected <span>Projects</span></h2>
        </div>

        {projects.length === 0 ? (
            <p class="text-muted font-mono" style="font-size:0.875rem;">No projects yet.</p>
        ) : (
            <div class="carousel-wrapper">
            <div class="projects-carousel">
                {projects.map((p, i) => {
                    const slug = p.web_profile?.data?.slug ?? "";
                    const accent = p.web_profile?.data?.accent ?? "var(--green)";
                    const stack = p.web_profile?.data?.stack ?? [];
                    const images = p.web_profile?.data?.images ?? [];
                    const links = p.web_profile?.data?.links ?? [];
                    const thumb = images[0] ?? null;

                    return (
                        <a
                            href={`/projects/${slug}`}
                            class="project-card reveal"
                            style={`--accent: ${accent};`}
                        >
                            {thumb && (
                                <div class="project-thumb">
                                    <img src={thumb} alt={p.title} loading="lazy" />
                                </div>
                            )}
                            <div class="project-num">{String(i + 1).padStart(2, "0")}</div>
                            <div class="project-body">
                                <div class="project-top">
                                    <div>
                                        <p class="project-slug font-mono text-muted">{slug}.ts</p>
                                        <h3 class="project-name">{p.title}</h3>
                                    </div>
                                    <div class="project-links-count font-mono">
                                        {links.length > 0 && (
                                            <span class="link-badge">{links.length} link{links.length > 1 ? "s" : ""}</span>
                                        )}
                                    </div>
                                </div>
                                <p class="project-desc">{p.description}</p>
                                <div class="project-tags">
                                    {stack.map((tag) => (
                                        <span class="tag">{tag}</span>
                                    ))}
                                </div>
                            </div>
                            <div class="project-accent-bar" />
                        </a>
                    );
                })}
            </div>
            </div>
        )}
    </div>
</section>

<style>
    .carousel-wrapper {
        position: relative;
        margin: 0 calc(-1 * clamp(1.5rem, 5vw, 3rem));
    }

    .carousel-wrapper::before,
    .carousel-wrapper::after {
        content: "";
        position: absolute;
        top: 0;
        bottom: 1rem;
        width: clamp(2rem, 6vw, 4rem);
        z-index: 2;
        pointer-events: none;
    }

    .carousel-wrapper::before {
        left: 0;
        background: linear-gradient(to right, var(--bg), transparent);
    }

    .carousel-wrapper::after {
        right: 0;
        background: linear-gradient(to left, var(--bg), transparent);
    }

    .projects-carousel {
        display: flex;
        gap: 1.5rem;
        overflow-x: auto;
        overflow-y: visible;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        padding: 10px clamp(1.5rem, 5vw, 3rem) 1rem;
        scrollbar-width: none;
    }

    .projects-carousel::-webkit-scrollbar {
        display: none;
    }

    .project-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 1.5rem;
        position: relative;
        overflow: hidden;
        transition: border-color 0.3s var(--ease), box-shadow 0.3s var(--ease), transform 0.3s var(--ease);
        display: flex;
        flex-direction: column;
        gap: 1rem;
        text-decoration: none;
        color: inherit;
        scroll-snap-align: start;
        flex: 0 0 300px;
        min-height: 240px;
    }

    .project-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(
            ellipse at top right,
            rgba(var(--accent-rgb, 0, 255, 136), 0.06),
            transparent 60%
        );
        opacity: 0;
        transition: opacity 0.35s var(--ease);
    }

    .project-card:hover {
        border-color: var(--accent);
        transform: translateY(-6px);
        box-shadow: 0 16px 40px rgba(0, 0, 0, 0.25);
        color: inherit;
    }

    .project-card:hover::before {
        opacity: 1;
    }

    .project-thumb {
        width: 100%;
        height: 160px;
        border-radius: 8px;
        overflow: hidden;
        margin-bottom: -0.25rem;
        flex-shrink: 0;
    }

    .project-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.35s var(--ease);
    }

    .project-card:hover .project-thumb img {
        transform: scale(1.04);
    }

    .project-accent-bar {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg, var(--accent), transparent);
        opacity: 0;
        transition: opacity 0.35s var(--ease);
    }

    .project-card:hover .project-accent-bar {
        opacity: 1;
    }

    .project-num {
        font-family: var(--font-mono);
        font-size: 2.5rem;
        font-weight: 800;
        color: var(--accent);
        opacity: 0.12;
        line-height: 1;
        transition: opacity 0.3s var(--ease);
        user-select: none;
    }

    .project-card:hover .project-num {
        opacity: 0.25;
    }

    .project-body {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        flex: 1;
    }

    .project-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
    }

    .project-slug {
        font-size: 0.7rem;
        margin-bottom: 0.25rem;
    }

    .project-name {
        font-size: 1.125rem;
        font-weight: 700;
        color: var(--text);
        line-height: 1.2;
    }

    .link-badge {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        color: var(--accent);
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 4px;
        padding: 0.15rem 0.5rem;
        white-space: nowrap;
    }

    .project-desc {
        font-size: 0.875rem;
        color: var(--text-muted);
        line-height: 1.65;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .project-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: auto;
    }

    .tag {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--accent);
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 4px;
        padding: 0.2rem 0.625rem;
        transition: border-color var(--duration) var(--ease);
    }

    .project-card:hover .tag {
        border-color: rgba(var(--accent-rgb, 0, 255, 136), 0.3);
    }

    @media (max-width: 768px) {
        .project-card {
            flex: 0 0 260px;
        }

        .project-card:hover {
            transform: none;
        }

        .carousel-wrapper::before,
        .carousel-wrapper::after {
            width: 2.5rem;
        }
    }
</style>
