---
import GithubIcon from "../assets/icons/GithubIcon.astro";
import ExternalLinkIcon from "../assets/icons/ExternalLinkIcon.astro";

const projects = [
    {
        num: "01",
        name: "Warehouse Management System (WMS)",
        slug: "warehouse-system",
        desc: "Designed for warehouse monitoring activities such as picking, storing, and tracking inventory. Boosted tracking by 50%.",
        stack: ["React Native", "Express JS"],
        accent: "var(--green)",
        links: { github: "#", live: "#" },
    },
    {
        num: "02",
        name: "HRIS Mobile Application",
        slug: "hris-mobile",
        desc: "Enterprise employee management platform for tracking activities, calculating salaries, and viewing payslips. Improved user satisfaction by 40%.",
        stack: ["Flutter", "Spring Boot", "Java"],
        accent: "var(--cyan)",
        links: { github: "#", live: "#" },
    },
    {
        num: "03",
        name: "Sales Force Application",
        slug: "sales-app-mobile",
        desc: "Mobile application for sales activities, including product catalogs, customer visits tracking, quotations, and payment calculations.",
        stack: ["React Native", "Javascript", "Restful API"],
        accent: "var(--purple)",
        links: { github: "#", live: "#" },
    },
    {
        num: "04",
        name: "Employee ID System",
        slug: "employee-identification",
        desc: "Website for employee identification using multifunctional ID cards, enabling quick retrieval of employee information through QR scanning.",
        stack: ["React JS", "Node.js"],
        accent: "var(--yellow)",
        links: { github: "#", live: "#" },
    },
    {
        num: "05",
        name: "Job Application Dashboard",
        slug: "job-application-portal",
        desc: "Web platform serving as a comprehensive dashboard for prospective employees to apply and track their applications.",
        stack: ["Next JS", "Golang", "PostgreSQL"],
        accent: "var(--green)",
        links: { github: "#", live: "#" },
    },
];
---

<section class="section" id="projects">
    <div class="container">
        <div class="section-header reveal">
            <p class="section-label">portfolio</p>
            <h2 class="section-title">Selected <span>Projects</span></h2>
        </div>

        <div class="projects-grid">
            {
                projects.map((p) => (
                    <article
                        class="project-card reveal"
                        style={`--accent: ${p.accent}`}
                    >
                        <div class="project-num">{p.num}</div>
                        <div class="project-body">
                            <div class="project-top">
                                <div>
                                    <p class="project-slug font-mono text-muted">
                                        {p.slug}.ts
                                    </p>
                                    <h3 class="project-name">{p.name}</h3>
                                </div>
                                <div class="project-links">
                                    <a
                                        href={p.links.github}
                                        class="icon-link"
                                        title="GitHub"
                                        aria-label="GitHub"
                                    >
                                        <GithubIcon width="16" height="16" />
                                    </a>
                                    <a
                                        href={p.links.live}
                                        class="icon-link"
                                        title="Live Demo"
                                        aria-label="Live Demo"
                                    >
                                        <ExternalLinkIcon
                                            width="16"
                                            height="16"
                                        />
                                    </a>
                                </div>
                            </div>
                            <p class="project-desc">{p.desc}</p>
                            <div class="project-tags">
                                {p.stack.map((tag) => (
                                    <span class="tag">{tag}</span>
                                ))}
                            </div>
                        </div>
                        <div class="project-accent-bar" />
                    </article>
                ))
            }
        </div>
    </div>
</section>

<style>
    .projects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.5rem;
    }

    .project-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.5rem;
        position: relative;
        overflow: hidden;
        transition: all 0.35s var(--ease);
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .project-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(
            ellipse at top right,
            rgba(var(--accent-rgb, 0, 255, 136), 0.06),
            transparent 60%
        );
        opacity: 0;
        transition: opacity 0.35s var(--ease);
    }

    .project-card:hover {
        border-color: var(--accent);
        transform: translateY(-6px);
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    }

    .project-card:hover::before {
        opacity: 1;
    }

    .project-accent-bar {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg, var(--accent), transparent);
        opacity: 0;
        transition: opacity 0.35s var(--ease);
    }

    .project-card:hover .project-accent-bar {
        opacity: 1;
    }

    .project-num {
        font-family: var(--font-mono);
        font-size: 2.5rem;
        font-weight: 800;
        color: var(--accent);
        opacity: 0.12;
        line-height: 1;
        transition: opacity 0.3s var(--ease);
        user-select: none;
    }

    .project-card:hover .project-num {
        opacity: 0.25;
    }

    .project-body {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .project-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
    }

    .project-slug {
        font-size: 0.7rem;
        margin-bottom: 0.25rem;
    }

    .project-name {
        font-size: 1.125rem;
        font-weight: 700;
        color: var(--text);
        line-height: 1.2;
    }

    .project-links {
        display: flex;
        gap: 0.5rem;
        flex-shrink: 0;
    }

    .icon-link {
        color: var(--text-muted);
        padding: 0.4rem;
        border-radius: 6px;
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        transition: all var(--duration) var(--ease);
    }

    .icon-link:hover {
        color: var(--accent);
        border-color: var(--accent);
        background: rgba(var(--accent-rgb, 0, 255, 136), 0.08);
    }

    .project-desc {
        font-size: 0.875rem;
        color: var(--text-muted);
        line-height: 1.65;
    }

    .project-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .tag {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--accent);
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 4px;
        padding: 0.2rem 0.625rem;
        transition: border-color var(--duration) var(--ease);
    }

    .project-card:hover .tag {
        border-color: rgba(var(--accent-rgb, 0, 255, 136), 0.3);
    }
</style>
