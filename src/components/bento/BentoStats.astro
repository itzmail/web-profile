---
---

<div class="bento-card bento-card--stats">
    <div class="stats-list">
        <div class="stat-item">
            <span class="stat-big text-green font-mono">3+</span>
            <span class="stat-lbl">Years Experience</span>
        </div>
        <div class="stat-sep"></div>
        <div class="stat-item">
            <span class="stat-big text-cyan font-mono">10+</span>
            <span class="stat-lbl">Mobile Apps</span>
        </div>
        <div class="stat-sep"></div>
        <div class="stat-item">
            <span class="stat-big text-purple font-mono">3</span>
            <span class="stat-lbl">Key Achievements</span>
        </div>
    </div>
</div>

<style>
    .bento-card--stats {
        grid-column: 9 / 13;
        grid-row: 1;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .stats-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        width: 100%;
    }

    .stat-item {
        text-align: center;
    }

    .stat-big {
        font-size: 2.25rem;
        font-weight: 800;
        line-height: 1;
        display: block;
    }

    .stat-lbl {
        font-size: 0.7rem;
        color: var(--text-muted);
        margin-top: 0.2rem;
    }

    .stat-sep {
        height: 1px;
        background: var(--border);
    }

    @media (max-width: 1024px) {
        .bento-card--stats {
            grid-column: 1 / -1;
        }

        .stats-list {
            flex-direction: row;
            justify-content: center;
            gap: 2rem;
        }

        .stat-sep {
            width: 1px;
            height: 40px;
        }
    }
</style>
