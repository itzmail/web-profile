---
import type { ApiStats } from "../../types/index";

interface Props {
    stats: ApiStats;
}

const { stats } = Astro.props;
---

<div class="bento-card bento-card--stats">
    <div class="bento-label">// stats</div>
    <div class="stats-list">
        <div class="stat-item">
            <span class="stat-big text-green font-mono">{stats.years_exp}</span>
            <span class="stat-lbl">Years Experience</span>
        </div>
        <div class="stat-sep"></div>
        <div class="stat-item">
            <span class="stat-big text-cyan font-mono">{stats.total_projects}</span>
            <span class="stat-lbl">Projects</span>
        </div>
        <div class="stat-sep"></div>
        <div class="stat-row">
            <div class="stat-item-sm">
                <span class="stat-med text-purple font-mono">{stats.prod_apps}</span>
                <span class="stat-lbl-sm">Prod Apps</span>
            </div>
            <div class="stat-divider">|</div>
            <div class="stat-item-sm">
                <span class="stat-med text-green font-mono">{stats.open_source}</span>
                <span class="stat-lbl-sm">Open Source</span>
            </div>
        </div>
    </div>
</div>

<style>
    .bento-card--stats {
        grid-column: 9 / 13;
        grid-row: 1;
        display: flex;
        flex-direction: column;
    }

    .stats-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        width: 100%;
        flex: 1;
        justify-content: center;
    }

    .stat-item {
        text-align: center;
    }

    .stat-big {
        font-size: 2.25rem;
        font-weight: 800;
        line-height: 1;
        display: block;
    }

    .stat-lbl {
        font-size: 0.7rem;
        color: var(--text-muted);
        margin-top: 0.2rem;
        display: block;
    }

    .stat-sep {
        height: 1px;
        background: var(--border);
    }

    .stat-row {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
    }

    .stat-item-sm {
        text-align: center;
        flex: 1;
    }

    .stat-med {
        font-size: 1.5rem;
        font-weight: 700;
        line-height: 1;
        display: block;
    }

    .stat-lbl-sm {
        font-size: 0.65rem;
        color: var(--text-muted);
        margin-top: 0.15rem;
        display: block;
    }

    .stat-divider {
        color: var(--border);
        font-size: 1.25rem;
        line-height: 1;
        user-select: none;
    }

    @media (max-width: 1024px) {
        .bento-card--stats {
            grid-column: 1 / -1;
        }

        .stats-list {
            flex-direction: row;
            justify-content: center;
            gap: 2rem;
        }

        .stat-sep {
            width: 1px;
            height: 40px;
        }

        .stat-row {
            flex-direction: column;
            gap: 0.25rem;
        }

        .stat-divider {
            display: none;
        }
    }
</style>
