---
import type { Experience } from "../../types/index";

interface Props {
    experiences: Experience[];
}

const { experiences } = Astro.props;
---

<button
    class="bento-card bento-card--experience-list global-modal-trigger"
    data-template-id="tpl-experience"
    data-modal-title="Work Experience"
    data-modal-subtitle="Career Timeline"
>
    <div class="bento-label">// work experience</div>
    <div class="quote-content-large" style="text-align: left;">
        <span
            class="font-mono text-green"
            style="font-size:3rem; line-height:1; margin-bottom:0.5rem"
            >{experiences.length}</span
        >
        <span class="text-muted" style="font-size:0.9rem">Companies</span>
    </div>
    <div class="bento-card-action">
        <span
            class="font-mono text-green"
            style="font-size: 0.75rem; letter-spacing: 0.05em;"
            >View Timeline &rarr;</span
        >
    </div>
</button>

<template id="tpl-experience">
    <div class="timeline-container">
        {
            experiences.map((e) => {
                const { title, description, web_profile } = e;
                const { date, accent, company } = web_profile.data;
                const bullets = description
                    .split("\n")
                    .map((s) => s.trim())
                    .filter(Boolean);
                return (
                    <div class="timeline-item">
                        <div class="timeline-dot" />
                        <div class="timeline-content">
                            <h4 class="timeline-role">{title}</h4>
                            <span
                                class="timeline-company font-mono"
                                style={`color: ${accent}`}
                            >
                                {company}
                            </span>
                            <span class="timeline-date text-muted">{date}</span>
                            <ul class="timeline-desc text-muted">
                                {bullets.map((b) => (
                                    <li>{b}</li>
                                ))}
                            </ul>
                        </div>
                    </div>
                );
            })
        }
    </div>
</template>

<style>
    .bento-card--experience-list {
        grid-column: 7 / 13;
        grid-row: 2;
    }

    /* Timeline styles injected into modal */
    .timeline-container {
        position: relative;
        padding-left: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .timeline-container::before {
        content: "";
        position: absolute;
        left: 3px;
        top: 0;
        bottom: 0;
        width: 2px;
        background: rgba(0, 255, 136, 0.2);
    }

    .timeline-item {
        position: relative;
    }

    .timeline-dot {
        position: absolute;
        left: -1.5rem;
        top: 0.25rem;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: var(--surface);
        border: 2px solid var(--green);
        transform: translateX(-1px);
    }

    .timeline-content {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .timeline-role {
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--text);
        margin: 0;
    }

    .timeline-company {
        font-size: 0.85rem;
    }

    .timeline-date {
        font-size: 0.75rem;
        margin-bottom: 0.5rem;
    }

    .timeline-desc {
        padding-left: 1.1rem;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        font-size: 0.8rem;
        line-height: 1.6;
    }

    @media (max-width: 768px) {
        .bento-card--experience-list {
            grid-column: 1 / -1;
        }
    }
</style>
