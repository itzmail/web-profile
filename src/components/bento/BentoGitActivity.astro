---
---

<div class="bento-card bento-card--git">
    <div class="bento-label" style="display:flex; justify-content:space-between; align-items:center;">
        <span>// git contributions (last year)</span>
        <span id="git-total" class="text-green font-mono" style="font-size:0.65rem;">...</span>
    </div>
    <div class="git-heatmap-wrap">
        <div class="git-month-labels" id="git-months"></div>
        <div class="git-grid-wrap">
            <div class="git-day-labels">
                <span></span>
                <span>Mon</span>
                <span></span>
                <span>Wed</span>
                <span></span>
                <span>Fri</span>
                <span></span>
            </div>
            <div id="git-grid" class="git-grid"></div>
        </div>
        <div class="git-legend">
            <span class="git-legend-label">Less</span>
            <span class="git-cell" data-level="0"></span>
            <span class="git-cell" data-level="1"></span>
            <span class="git-cell" data-level="2"></span>
            <span class="git-cell" data-level="3"></span>
            <span class="git-cell" data-level="4"></span>
            <span class="git-legend-label">More</span>
        </div>
    </div>
</div>

<script>
    async function loadGitActivity() {
        try {
            const res = await fetch("/api/git-activity");
            if (!res.ok) return;

            const data = await res.json() as {
                days: { date: string; count: number }[];
                total: number;
            };

            const totalEl = document.getElementById("git-total");
            if (totalEl) totalEl.textContent = `${data.total.toLocaleString()} contributions in the last year`;

            const grid = document.getElementById("git-grid");
            const monthsEl = document.getElementById("git-months");
            if (!grid || !monthsEl) return;

            // Group days into weeks (columns)
            const weeks: { date: string; count: number }[][] = [];
            let week: { date: string; count: number }[] = [];

            for (const day of data.days) {
                week.push(day);
                if (week.length === 7) {
                    weeks.push(week);
                    week = [];
                }
            }
            if (week.length > 0) weeks.push(week);

            // Max count for intensity scaling
            const maxCount = Math.max(...data.days.map((d) => d.count), 1);

            function getLevel(count: number): number {
                if (count === 0) return 0;
                const ratio = count / maxCount;
                if (ratio <= 0.25) return 1;
                if (ratio <= 0.5) return 2;
                if (ratio <= 0.75) return 3;
                return 4;
            }

            // Build grid columns
            grid.innerHTML = weeks.map((w) =>
                `<div class="git-week">${w.map((day) =>
                    `<span class="git-cell" data-level="${getLevel(day.count)}" title="${day.date}: ${day.count} contribution${day.count !== 1 ? "s" : ""}"></span>`
                ).join("")}</div>`
            ).join("");

            // Month labels — find first Sunday of each month
            const monthNames = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
            const labels: { weekIdx: number; label: string }[] = [];
            weeks.forEach((w, i) => {
                if (w[0]) {
                    const d = new Date(w[0].date);
                    // Show label on the week where the month first appears
                    if (i === 0 || new Date(weeks[i-1][0].date).getMonth() !== d.getMonth()) {
                        labels.push({ weekIdx: i, label: monthNames[d.getMonth()] });
                    }
                }
            });

            monthsEl.innerHTML = labels.map((l) =>
                `<span style="grid-column: ${l.weekIdx + 1}">${l.label}</span>`
            ).join("");

        } catch (e) {
            console.error("Failed to load git activity", e);
        }
    }

    loadGitActivity();
</script>

<style>
    .bento-card--git {
        grid-column: 1 / -1;
        grid-row: 4;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .git-heatmap-wrap {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        overflow-x: auto;
    }

    .git-month-labels {
        display: grid;
        grid-template-columns: repeat(53, 1fr);
        padding-left: 2rem;
        font-family: var(--font-mono);
        font-size: 0.6rem;
        color: var(--text-muted);
        min-width: 600px;
    }

    .git-month-labels span {
        white-space: nowrap;
    }

    .git-grid-wrap {
        display: flex;
        gap: 0.35rem;
        align-items: flex-start;
        min-width: 600px;
    }

    .git-day-labels {
        display: grid;
        grid-template-rows: repeat(7, 12px);
        gap: 2px;
        font-family: var(--font-mono);
        font-size: 0.55rem;
        color: var(--text-muted);
        padding-top: 1px;
        flex-shrink: 0;
        width: 1.75rem;
        text-align: right;
    }

    .git-grid {
        display: flex;
        gap: 2px;
        flex: 1;
    }

    .git-week {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .git-cell {
        width: 12px;
        height: 12px;
        border-radius: 2px;
        background: var(--surface-2, rgba(255,255,255,0.04));
        transition: background 0.15s;
        cursor: default;
    }

    .git-cell[data-level="0"] { background: rgba(255,255,255,0.05); }
    .git-cell[data-level="1"] { background: #0e4429; }
    .git-cell[data-level="2"] { background: #006d32; }
    .git-cell[data-level="3"] { background: #26a641; }
    .git-cell[data-level="4"] { background: #39d353; box-shadow: 0 0 6px rgba(57,211,83,0.4); }

    .git-cell:hover {
        outline: 1px solid rgba(255,255,255,0.3);
    }

    .git-legend {
        display: flex;
        align-items: center;
        gap: 4px;
        justify-content: flex-end;
        padding-right: 0.25rem;
    }

    .git-legend-label {
        font-family: var(--font-mono);
        font-size: 0.6rem;
        color: var(--text-muted);
        margin: 0 2px;
    }

    @media (max-width: 768px) {
        .bento-card--git {
            grid-column: 1 / -1;
        }
    }
</style>
