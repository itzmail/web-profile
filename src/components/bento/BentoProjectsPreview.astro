---
import type { Project } from "../../types/index";
import ArrowRightIcon from "../../assets/icons/ArrowRightIcon.astro";

interface Props {
    projects: Project[];
}

const { projects } = Astro.props;
---

<button
    class="bento-card bento-card--projects-list global-modal-trigger"
    data-template-id="tpl-projects"
    data-modal-title="Selected Projects"
    data-modal-subtitle="Portfolio & Open Source"
>
    <div class="bento-label">// selected projects</div>
    <div class="quote-content-large" style="text-align: left;">
        <span
            class="font-mono text-cyan"
            style="font-size:3rem; line-height:1; margin-bottom:0.5rem"
            >{projects.length}</span
        >
        <span class="text-muted" style="font-size:0.9rem"
            >Portfolio Applications</span
        >
    </div>
    <div class="bento-card-action">
        <span
            class="font-mono text-cyan"
            style="font-size: 0.75rem; letter-spacing: 0.05em;"
            >View Projects &rarr;</span
        >
    </div>
</button>

<template id="tpl-projects">
    <div class="plist-container">
        {
            projects.map((p, i) => (
                <a
                    href={p.links.live !== "#" ? p.links.live : p.links.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="plist-item"
                    style="text-decoration: none;"
                >
                    <span
                        class="plist-num font-mono"
                        style={`color: ${p.accent}`}
                    >
                        0{i + 1}
                    </span>
                    <div class="plist-text-single">
                        <span class="plist-name">{p.name}</span>
                    </div>
                    <ArrowRightIcon
                        class="plist-arrow"
                        width="14"
                        height="14"
                    />
                </a>
            ))
        }
    </div>
</template>

<style>
    .bento-card--projects-list {
        grid-column: 1 / 7;
        grid-row: 2;
    }

    .plist-container {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .plist-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--border);
        text-align: left;
        cursor: pointer;
        transition: all 0.2s;
        width: 100%;
        color: var(--text);
    }

    .plist-item:hover {
        border-color: var(--border-glow);
        background: var(--green-glow);
        transform: translateX(4px);
    }

    .plist-num {
        font-size: 0.8rem;
        min-width: 20px;
    }

    .plist-text-single {
        display: flex;
        flex: 1;
        align-items: center;
    }

    .plist-name {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--text);
    }

    .plist-arrow {
        color: var(--text-dim);
        transition: transform 0.2s var(--ease), color 0.2s var(--ease);
    }

    .plist-item:hover .plist-arrow {
        color: var(--green);
        transform: translateX(3px);
    }

    @media (max-width: 768px) {
        .bento-card--projects-list {
            grid-column: 1 / -1;
        }
    }
</style>
