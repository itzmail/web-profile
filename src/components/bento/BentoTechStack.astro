---
import type { SkillGroup } from "../../types/index";

interface Props {
    skillGroups: SkillGroup[];
}

const { skillGroups } = Astro.props;

const categoryColors: Record<string, string> = {
    Backend: "var(--green)",
    Frontend: "var(--cyan)",
    Mobile: "var(--purple)",
    Language: "#f0c674",
    Database: "#e06c75",
    Tools: "var(--text-muted)",
};

const totalSkills = skillGroups.reduce((acc, g) => acc + g.items.length, 0);
---

<button
    class="bento-card bento-card--stack global-modal-trigger"
    data-template-id="tpl-skills"
    data-modal-title="Tech Stack"
    data-modal-subtitle={`${totalSkills} technologies`}
    id="stack"
>
    <div class="bento-label">// tech stack</div>

    <div class="stack-grid">
        {skillGroups.map((group) => (
            <div class="category-block">
                <span
                    class="cat-label font-mono"
                    style={`color: ${categoryColors[group.category] ?? "var(--text-muted)"}`}
                >
                    {group.category}
                </span>
                <div class="badge-row">
                    {group.items.slice(0, 3).map((item) => (
                        <span class="skill-badge">
                            <img
                                src={item.metadata.icon}
                                alt={item.value}
                                class="badge-icon"
                                width="13"
                                height="13"
                                loading="lazy"
                            />
                            <span class="badge-label">{item.value}</span>
                        </span>
                    ))}
                    {group.items.length > 3 && (
                        <span class="badge-more">+{group.items.length - 3}</span>
                    )}
                </div>
            </div>
        ))}
    </div>

    <div class="stack-footer">
        <span class="stack-count font-mono">{totalSkills} technologies</span>
        <span class="see-all font-mono">See all &rarr;</span>
    </div>
</button>

<template id="tpl-skills">
    <div class="modal-skills">
        {skillGroups.map((group) => (
            <div class="modal-group">
                <span
                    class="modal-cat font-mono"
                    style={`color: ${categoryColors[group.category] ?? "var(--text-muted)"}`}
                >
                    {group.category}
                </span>
                <div class="modal-badge-row">
                    {group.items.map((item) => (
                        <span class="skill-badge skill-badge--lg">
                            <img
                                src={item.metadata.icon}
                                alt={item.value}
                                class="badge-icon"
                                width="15"
                                height="15"
                                loading="lazy"
                            />
                            <span class="badge-label">{item.value}</span>
                        </span>
                    ))}
                </div>
            </div>
        ))}
    </div>
</template>

<style>
    .bento-card--stack {
        grid-column: 1 / 5;
        grid-row: 3;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        cursor: pointer;
        text-align: left;
        width: 100%;
    }

    /* ── Grid ── */
    .stack-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.875rem 1rem;
        flex: 1;
    }

    .category-block {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    .cat-label {
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
    }

    .badge-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem;
    }

    /* ── Badge ── */
    .skill-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        font-family: var(--font-mono);
        font-size: 0.67rem;
        color: var(--text-muted);
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--border);
        border-radius: 99px;
        padding: 0.18rem 0.55rem 0.18rem 0.4rem;
        white-space: nowrap;
        transition: all 0.18s var(--ease);
    }

    .bento-card--stack:hover .skill-badge {
        color: var(--text);
        border-color: rgba(255, 255, 255, 0.1);
    }

    .skill-badge--lg {
        font-size: 0.72rem;
        padding: 0.22rem 0.65rem 0.22rem 0.45rem;
    }

    .badge-icon {
        width: 13px;
        height: 13px;
        object-fit: contain;
        flex-shrink: 0;
    }

    .badge-more {
        display: inline-flex;
        align-items: center;
        font-family: var(--font-mono);
        font-size: 0.62rem;
        color: var(--text-dim);
        border: 1px dashed rgba(255, 255, 255, 0.12);
        border-radius: 99px;
        padding: 0.18rem 0.45rem;
    }

    /* ── Footer ── */
    .stack-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 0.75rem;
        border-top: 1px solid var(--border);
        margin-top: auto;
    }

    .stack-count {
        font-size: 0.65rem;
        color: var(--text-dim);
        letter-spacing: 0.04em;
    }

    .see-all {
        font-size: 0.7rem;
        color: var(--green);
        opacity: 0.8;
        transition: opacity 0.2s, letter-spacing 0.2s;
    }

    .bento-card--stack:hover .see-all {
        opacity: 1;
        letter-spacing: 0.02em;
    }

    /* ── Modal content ── */
    .modal-skills {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .modal-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .modal-cat {
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
    }

    .modal-badge-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.375rem;
    }

    /* ── Responsive ── */
    @media (max-width: 1024px) {
        .bento-card--stack {
            grid-column: 1 / -1;
        }
    }

    @media (max-width: 640px) {
        .stack-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 400px) {
        .stack-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
