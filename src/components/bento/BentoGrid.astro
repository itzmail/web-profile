---
import { getWakatimeData } from "../../utils/wakatime";
import { apiFetch } from "../../utils/api";
import type { Experience, ApiProject, ApiCertificate, MasterSkillItem, SkillGroup } from "../../types/index";

import BentoProfile from "./BentoProfile.astro";
import BentoStats from "./BentoStats.astro";
import BentoCertificatesPreview from "./BentoCertificatesPreview.astro";
import BentoExperiencePreview from "./BentoExperiencePreview.astro";
import BentoTechStack from "./BentoTechStack.astro";
import BentoLocation from "./BentoLocation.astro";
import BentoWakatime from "./BentoWakatime.astro";

interface MasterResponse { items: MasterSkillItem[]; }

const [apiExperiences, apiCertificates, apiSkills, wakatimeData] = await Promise.all([
    apiFetch<Experience[]>("/experiences"),
    apiFetch<ApiCertificate[]>("/certificates"),
    apiFetch<MasterResponse>("/master/skills"),
    getWakatimeData(),
]);

const experiences: Experience[] = apiExperiences ?? [];

const certificates = apiCertificates ?? [];

const skillGroups: SkillGroup[] = [];
if (apiSkills) {
    const map = new Map<string, MasterSkillItem[]>();
    for (const item of apiSkills.items) {
        const cat = item.metadata.category;
        if (!map.has(cat)) map.set(cat, []);
        map.get(cat)!.push(item);
    }
    for (const [category, items] of map) {
        skillGroups.push({ category, items });
    }
}
---

<section class="section bento-section" id="bento">
    <div class="container">
        <div class="bento-grid">
            <BentoProfile />
            <BentoStats />
            <BentoCertificatesPreview certificates={certificates} />
            <BentoExperiencePreview experiences={experiences} />
            <BentoTechStack skillGroups={skillGroups} />
            <BentoLocation />
            <BentoWakatime wakatime={wakatimeData} />
        </div>
    </div>
</section>

<style>
    .bento-section {
        padding-bottom: 3rem;
    }

    /* ── Bento Grid container ─────────────────────────── */
    .bento-grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        grid-auto-rows: auto;
        gap: 1rem;
    }

    /* ── Base Card (shared by all bento sub-components) ─ */
    :global(.bento-card) {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 1.5rem;
        position: relative;
        overflow: hidden;
        transition: border-color 0.3s var(--ease), transform 0.3s var(--ease),
            box-shadow 0.3s var(--ease);
    }

    :global(.bento-card:hover) {
        border-color: var(--border-glow);
        transform: translateY(-3px);
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4), 0 0 24px var(--green-glow);
    }

    :global(.bento-label) {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        color: var(--text-muted);
        letter-spacing: 0.1em;
        margin-bottom: 1rem;
    }

    :global(.quote-content-large) {
        display: flex;
        flex-direction: column;
        justify-content: center;
        flex: 1;
    }

    :global(.bento-card-action) {
        margin-top: auto;
        padding-top: 1rem;
    }

    /* ── Responsive grid overrides ───────────────────── */
    @media (max-width: 1024px) {
        :global(.bento-card) {
            grid-row: auto !important;
        }

        :global(.bento-card--featured) {
            grid-column: 1 / -1;
        }
    }
</style>
