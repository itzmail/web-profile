---
import { projectsList } from "../../data/projects";
import { experienceList } from "../../data/experience";
import { getWakatimeData } from "../../utils/wakatime";
import type { Experience } from "../../types/index";

import Contact from "../Contact.astro";
import BentoProfile from "./BentoProfile.astro";
import BentoStats from "./BentoStats.astro";
import BentoProjectsPreview from "./BentoProjectsPreview.astro";
import BentoExperiencePreview from "./BentoExperiencePreview.astro";
import BentoTechStack from "./BentoTechStack.astro";
import BentoLocation from "./BentoLocation.astro";
import BentoWakatime from "./BentoWakatime.astro";

let experiences: Experience[] = experienceList;
try {
    const res = await fetch("http://my-data.nuropia.my.id/api/experiences");
    if (res.ok) {
        experiences = await res.json();
    }
} catch {
    // API unavailable — fallback to static data
}

const wakatimeData = await getWakatimeData();
---

<section class="section bento-section" id="bento">
    <div class="container">
        <div class="bento-grid">
            <BentoProfile />
            <BentoStats />
            <BentoProjectsPreview projects={projectsList} />
            <BentoExperiencePreview experiences={experiences} />
            <BentoTechStack />
            <BentoLocation />
            <BentoWakatime wakatime={wakatimeData} />
        </div>
    </div>
</section>

<Contact />

<style>
    .bento-section {
        padding-bottom: 3rem;
    }

    /* ── Bento Grid container ─────────────────────────── */
    .bento-grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        grid-auto-rows: auto;
        gap: 1rem;
    }

    /* ── Base Card (shared by all bento sub-components) ─ */
    :global(.bento-card) {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 1.5rem;
        position: relative;
        overflow: hidden;
        transition: border-color 0.3s var(--ease), transform 0.3s var(--ease),
            box-shadow 0.3s var(--ease);
    }

    :global(.bento-card:hover) {
        border-color: var(--border-glow);
        transform: translateY(-3px);
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4), 0 0 24px var(--green-glow);
    }

    :global(.bento-label) {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        color: var(--text-muted);
        letter-spacing: 0.1em;
        margin-bottom: 1rem;
    }

    :global(.quote-content-large) {
        display: flex;
        flex-direction: column;
        justify-content: center;
        flex: 1;
    }

    :global(.bento-card-action) {
        margin-top: auto;
        padding-top: 1rem;
    }

    /* ── Responsive grid overrides ───────────────────── */
    @media (max-width: 1024px) {
        :global(.bento-card) {
            grid-row: auto !important;
        }

        :global(.bento-card--featured) {
            grid-column: 1 / -1;
        }
    }
</style>
