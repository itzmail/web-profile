---
import userPhoto from "../../assets/images/user-photo.JPG";
import QuoteIcon from "../../assets/icons/QuoteIcon.astro";
---

<article class="bento-card bento-card--featured" id="profile">
    <div class="featured-portrait-container">
        <img
            src={userPhoto.src}
            alt="Ismail Alam"
            class="featured-portrait"
        />
        <div class="portrait-overlay"></div>
    </div>

    <div class="quote-content-large">
        <QuoteIcon class="quote-icon-large" width="40" height="40" />
        <div class="quote-text-large">
            <span id="dynamic-typing-text" class="text-green font-mono"></span
            ><span class="typing-cursor">_</span>
        </div>
    </div>
</article>

<style>
    .bento-card--featured {
        grid-column: 1 / 9;
        grid-row: 1;
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 3rem;
        min-height: 240px;
        padding: 2.5rem;
        background: linear-gradient(
            135deg,
            rgba(0, 255, 136, 0.04),
            var(--surface)
        );
    }

    .featured-portrait-container {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        overflow: hidden;
        flex-shrink: 0;
        position: relative;
        border: 2px solid var(--border-glow);
        box-shadow: 0 0 20px rgba(0, 255, 136, 0.1);
        cursor: crosshair;
        transition: transform 0.4s var(--ease-spring),
            box-shadow 0.4s var(--ease);
    }

    .featured-portrait {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: top;
        filter: grayscale(100%) contrast(1.1);
        transition: filter 0.5s var(--ease), transform 0.5s var(--ease);
    }

    .portrait-overlay {
        position: absolute;
        inset: 0;
        background: var(--green-glow);
        mix-blend-mode: overlay;
        opacity: 0.8;
        transition: opacity 0.5s var(--ease);
        z-index: 1;
    }

    .featured-portrait-container:hover {
        transform: scale(1.05) rotate(-3deg);
        box-shadow: 0 0 30px rgba(0, 255, 136, 0.3),
            0 0 0 4px rgba(0, 255, 136, 0.1);
    }

    .featured-portrait-container:hover .featured-portrait {
        filter: grayscale(0%) contrast(1.05);
        transform: scale(1.1);
    }

    .featured-portrait-container:hover .portrait-overlay {
        opacity: 0;
    }

    .quote-content-large {
        display: flex;
        flex-direction: column;
        justify-content: center;
        flex: 1;
    }

    .quote-icon-large {
        color: var(--green);
        opacity: 0.2;
        margin-bottom: 0.75rem;
    }

    .quote-text-large {
        font-size: 1.5rem;
        line-height: 1.5;
        font-weight: 500;
        color: var(--text);
    }

    .typing-cursor {
        animation: blink 1s step-end infinite;
        color: var(--green);
    }

    @media (max-width: 768px) {
        .bento-card--featured {
            grid-column: 1 / -1;
            flex-direction: column;
            align-items: center;
            text-align: center;
            width: 100%;
        }

        .featured-portrait-container {
            width: 180px;
            height: 180px;
        }

        .quote-text-large {
            font-size: 1.25rem;
        }

        #profile {
          display: flex;
          flex-direction: column;
          flex: 1;
        }
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const typingText = document.getElementById("dynamic-typing-text");
        if (!typingText) return;

        const quotes = [
            "Turning coffee into code...",
            "Works on my machine 🤷‍♂️",
            "Writing bugs for a living.",
            "Git commit, push, pray.",
            "CTRL+C, CTRL+V Engineer.",
            "404: Sleep not found.",
            "It's not a bug, it's a feature.",
            "console.log('Here');",
        ];

        let quoteIndex = 0;
        let charIndex = 0;
        let isDeleting = false;
        let typingSpeed = 100;

        function type() {
            const currentQuote = quotes[quoteIndex];

            if (isDeleting) {
                typingText!.textContent = currentQuote.substring(
                    0,
                    charIndex - 1
                );
                charIndex--;
                typingSpeed = 50;
            } else {
                typingText!.textContent = currentQuote.substring(
                    0,
                    charIndex + 1
                );
                charIndex++;
                typingSpeed = 100;
            }

            if (!isDeleting && charIndex === currentQuote.length) {
                isDeleting = true;
                typingSpeed = 2000;
            } else if (isDeleting && charIndex === 0) {
                isDeleting = false;
                quoteIndex = (quoteIndex + 1) % quotes.length;
                typingSpeed = 500;
            }

            setTimeout(type, typingSpeed);
        }

        setTimeout(type, 1000);
    });
</script>
