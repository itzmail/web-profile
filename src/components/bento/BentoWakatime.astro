---
---

<div class="bento-card bento-card--contrib">
    <div
        class="bento-label"
        style="display:flex; justify-content:space-between;"
    >
        <span>// coding activity (7 days)</span>
        <span class="text-green font-mono" style="font-size:0.6rem;">● live</span>
    </div>
    <div class="waka-content">
        <div class="waka-header">
            <span id="waka-total" class="waka-time text-cyan font-mono">...</span>
            <span id="waka-avg" class="waka-subtitle">Avg: .../day</span>
        </div>
        <div id="waka-langs" class="waka-langs"></div>
    </div>
</div>

<script>
    async function loadWakatime() {
        try {
            const res = await fetch("/api/wakatime");
            if (!res.ok) return;
            const data = await res.json() as {
                human_readable_total_including_other_language?: string;
                human_readable_daily_average?: string;
                languages?: { name: string; percent: number }[];
            };

            const total = document.getElementById("waka-total");
            const avg = document.getElementById("waka-avg");
            const langs = document.getElementById("waka-langs");

            if (total) total.textContent = data.human_readable_total_including_other_language ?? "0 hrs";
            if (avg) avg.textContent = `Avg: ${data.human_readable_daily_average ?? "0 hrs"}/day`;

            if (langs && data.languages) {
                langs.innerHTML = data.languages.slice(0, 3).map((lang) => `
                    <div style="display:flex;flex-direction:column;gap:0.25rem;">
                        <div style="display:flex;justify-content:space-between;align-items:flex-end;font-size:0.75rem;">
                            <span style="font-weight:500;color:var(--text);">${lang.name}</span>
                            <span style="font-family:var(--font-mono);color:var(--text-muted);">${lang.percent}%</span>
                        </div>
                        <div style="height:4px;background:rgba(255,255,255,0.05);border-radius:4px;overflow:hidden;">
                            <div style="width:${lang.percent}%;height:100%;border-radius:4px;background:var(--green);box-shadow:0 0 10px var(--green-glow);"></div>
                        </div>
                    </div>
                `).join("");
            }
        } catch (e) {
            console.error("Failed to load wakatime", e);
        }
    }

    loadWakatime();
</script>

<style>
    .bento-card--contrib {
        grid-column: 9 / 13;
        grid-row: 3;
        display: flex;
        flex-direction: column;
    }

    .waka-content {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        margin-top: auto;
    }

    .waka-header {
        display: flex;
        flex-direction: column;
    }

    .waka-time {
        font-size: 1.5rem;
        font-weight: 700;
        line-height: 1;
        margin-bottom: 0.25rem;
    }

    .waka-subtitle {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .waka-langs {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .waka-lang-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 0.25rem;
        font-size: 0.75rem;
    }

    .waka-lang-name {
        font-weight: 500;
        color: var(--text);
    }

    .waka-progress-bg {
        height: 4px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 4px;
        overflow: hidden;
    }

    .waka-progress-bar {
        height: 100%;
        border-radius: 4px;
        box-shadow: 0 0 10px var(--green-glow);
    }

    @media (max-width: 1024px) {
        .bento-card--contrib {
            grid-column: 7 / 13;
        }
    }

    @media (max-width: 768px) {
        .bento-card--contrib {
            grid-column: 1 / -1;
        }
    }
</style>
