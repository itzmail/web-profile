---
const cvUrl = `${import.meta.env.PUBLIC_API_URL}/cv`;
---

<a
    href={cvUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="cv-fab"
    aria-label="View CV"
>
    <span class="cv-fab__icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14,2 14,8 20,8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10,9 9,9 8,9"/>
        </svg>
    </span>
    <span class="cv-fab__label">View CV</span>
</a>

<style>
    .cv-fab {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        z-index: 100;

        display: flex;
        align-items: center;
        gap: 0;

        background: var(--surface);
        border: 1px solid var(--border-glow);
        border-radius: 999px;
        color: var(--green);
        text-decoration: none;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.05em;

        box-shadow:
            0 0 12px rgba(0, 255, 136, 0.12),
            0 4px 16px rgba(0, 0, 0, 0.4);

        overflow: hidden;
        cursor: pointer;

        /* collapsed state: only icon visible */
        width: 44px;
        height: 44px;
        padding: 0 13px;

        transition:
            width 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
            padding 0.3s ease,
            box-shadow 0.3s ease,
            border-color 0.3s ease;
    }

    .cv-fab:hover,
    .cv-fab:focus-visible {
        width: 120px;
        padding: 0 16px 0 13px;
        border-color: var(--green);
        box-shadow:
            0 0 20px rgba(0, 255, 136, 0.25),
            0 6px 24px rgba(0, 0, 0, 0.5);
        outline: none;
    }

    .cv-fab__icon {
        display: flex;
        align-items: center;
        flex-shrink: 0;
    }

    .cv-fab__label {
        white-space: nowrap;
        overflow: hidden;
        max-width: 0;
        opacity: 0;
        margin-left: 0;
        transition:
            max-width 0.3s ease 0.05s,
            opacity 0.25s ease 0.1s,
            margin-left 0.3s ease;
    }

    .cv-fab:hover .cv-fab__label,
    .cv-fab:focus-visible .cv-fab__label {
        max-width: 80px;
        opacity: 1;
        margin-left: 8px;
    }

    @media (max-width: 480px) {
        .cv-fab {
            bottom: 1.25rem;
            right: 1.25rem;
        }
    }
</style>
