---
import userPhoto from "../assets/images/user-photo.JPG";
import { projectsList } from "../data/projects";
import { experienceList } from "../data/experience";
import Contact from "./Contact.astro";
import QuoteIcon from "../assets/icons/QuoteIcon.astro";
import ArrowRightIcon from "../assets/icons/ArrowRightIcon.astro";
import LocationIcon from "../assets/icons/LocationIcon.astro";
import { getWakatimeData } from "../utils/wakatime";

const wakatimeData = await getWakatimeData();
const topLanguages = wakatimeData?.languages?.slice(0, 3) || [];
const totalHours =
    wakatimeData?.human_readable_total_including_other_language || "0 hrs";
const dailyAverage = wakatimeData?.human_readable_daily_average || "0 hrs";
---

<!--
  BENTO GRID — Section 2
  Single responsive CSS grid mixing all content:
  projects, stack, experience, contact, stats, quote
-->
<section class="section bento-section" id="bento">
    <div class="container">
        <div class="bento-grid">
            <!-- ── CARD 1: Developer Quote & Portrait (wide) ── -->
            <article class="bento-card bento-card--featured" id="projects">
                <div class="featured-portrait-container">
                    <img
                        src={userPhoto.src}
                        alt="Ismail Alam"
                        class="featured-portrait"
                    />
                    <div class="portrait-overlay"></div>
                </div>

                <div class="quote-content-large">
                    <QuoteIcon
                        class="quote-icon-large"
                        width="40"
                        height="40"
                    />
                    <div class="quote-text-large">
                        <span
                            id="dynamic-typing-text"
                            class="text-green font-mono"></span><span
                            class="typing-cursor">_</span
                        >
                    </div>
                </div>
            </article>

            <!-- ── CARD 2: Stats ── -->
            <div class="bento-card bento-card--stats">
                <div class="stats-list">
                    <div class="stat-item">
                        <span class="stat-big text-green font-mono">3+</span>
                        <span class="stat-lbl">Years Experience</span>
                    </div>
                    <div class="stat-sep"></div>
                    <div class="stat-item">
                        <span class="stat-big text-cyan font-mono">10+</span>
                        <span class="stat-lbl">Mobile Apps</span>
                    </div>
                    <div class="stat-sep"></div>
                    <div class="stat-item">
                        <span class="stat-big text-purple font-mono">3</span>
                        <span class="stat-lbl">Key Achievements</span>
                    </div>
                </div>
            </div>

            <!-- ── CARD 4: Selected Projects (row 2) ── -->
            <button
                class="bento-card bento-card--projects-list global-modal-trigger"
                data-template-id="tpl-projects"
                data-modal-title="Selected Projects"
                data-modal-subtitle="Portfolio & Open Source"
            >
                <div class="bento-label">// selected projects</div>
                <div class="quote-content-large" style="text-align: left;">
                    <span
                        class="font-mono text-cyan"
                        style="font-size:3rem; line-height:1; margin-bottom:0.5rem"
                        >5</span
                    >
                    <span class="text-muted" style="font-size:0.9rem"
                        >Portfolio Applications</span
                    >
                </div>
                <div class="bento-card-action">
                    <span
                        class="font-mono text-cyan"
                        style="font-size: 0.75rem; letter-spacing: 0.05em;"
                        >View Projects &rarr;</span
                    >
                </div>
            </button>

            <!-- ── CARD 4b: Work Experience (row 2) ── -->
            <button
                class="bento-card bento-card--experience-list global-modal-trigger"
                data-template-id="tpl-experience"
                data-modal-title="Work Experience"
                data-modal-subtitle="Career Timeline"
            >
                <div class="bento-label">// work experience</div>
                <div class="quote-content-large" style="text-align: left;">
                    <span
                        class="font-mono text-green"
                        style="font-size:3rem; line-height:1; margin-bottom:0.5rem"
                        >3</span
                    >
                    <span class="text-muted" style="font-size:0.9rem"
                        >Companies</span
                    >
                </div>
                <div class="bento-card-action">
                    <span
                        class="font-mono text-green"
                        style="font-size: 0.75rem; letter-spacing: 0.05em;"
                        >View Timeline &rarr;</span
                    >
                </div>
            </button>

            <!-- ── CARD 3: Tech Stack (row 3) ── -->
            <div class="bento-card bento-card--stack" id="stack">
                <div class="bento-label">// tech stack</div>
                <div class="stack-pills">
                    <div class="pill-group">
                        <span class="pill-cat text-green">Backend</span>
                        <span class="pill">Express.js</span>
                        <span class="pill">Spring Boot</span>
                        <span class="pill">Java</span>
                        <span class="pill">Node.js</span>
                    </div>
                    <div class="pill-group">
                        <span class="pill-cat text-cyan">Frontend</span>
                        <span class="pill">React.js</span>
                        <span class="pill">Next.js</span>
                        <span class="pill">JavaScript</span>
                        <span class="pill">TypeScript</span>
                    </div>
                    <div class="pill-group">
                        <span class="pill-cat text-purple">Mobile</span>
                        <span class="pill">Flutter</span>
                        <span class="pill">React Native</span>
                        <span class="pill">Dart</span>
                    </div>
                    <div class="pill-group">
                        <span class="pill-cat" style="color:var(--yellow)"
                            >Tools</span
                        >
                        <span class="pill">Git</span>
                        <span class="pill">Bitbucket</span>
                        <span class="pill">REST API</span>
                    </div>
                </div>
            </div>

            <!-- ── CARD 7: Location & Time (row 3) ── -->
            <div class="bento-card bento-card--location">
                <div class="bento-label">// base location</div>
                <div class="location-content">
                    <div class="location-icon-wrapper">
                        <LocationIcon
                            class="location-icon text-green"
                            width="24"
                            height="24"
                        />
                    </div>
                    <div class="location-details">
                        <span class="location-city">Jakarta, Indonesia</span>
                        <div class="location-time">
                            <span class="time-dot"></span>
                            <span id="local-time" class="font-mono text-muted"
                                >00:00:00</span
                            >
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── CARD 6: Wakatime Stats (row 3) ── -->
            <div class="bento-card bento-card--contrib">
                <div
                    class="bento-label"
                    style="display:flex; justify-content:space-between;"
                >
                    <span>// coding activity (7 days)</span>
                    <span class="text-green font-mono" style="font-size:0.6rem;"
                        >● live</span
                    >
                </div>
                <div class="waka-content">
                    <div class="waka-header">
                        <span class="waka-time text-cyan font-mono"
                            >{totalHours}</span
                        >
                        <span class="waka-subtitle"
                            >Avg: {dailyAverage}/day</span
                        >
                    </div>

                    <div class="waka-langs">
                        {
                            topLanguages.map((lang: any) => (
                                <div class="waka-lang-item">
                                    <div class="waka-lang-top">
                                        <span class="waka-lang-name">
                                            {lang.name}
                                        </span>
                                        <span class="waka-lang-pct font-mono text-muted">
                                            {lang.percent}%
                                        </span>
                                    </div>
                                    <div class="waka-progress-bg">
                                        <div
                                            class="waka-progress-bar"
                                            style={`width: ${lang.percent}%; background: var(--green);`}
                                        />
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>

            <!-- ── CARD 5: Quote / Philosophy (row 4) ── -->
            <!-- <div class="bento-card bento-card--quote">
                <div class="quote-icon">"</div>
                <blockquote class="quote-text">
                    Make it work, make it<br />
                    <em class="text-green">right</em>, make it
                    <em class="text-cyan">fast</em>.
                </blockquote>
                <cite class="quote-cite font-mono text-muted"
                    >— engineering philosophy</cite
                >
            </div> -->
        </div><!-- /bento-grid -->
    </div>

    <!-- ── MODAL TEMPLATES ── -->
    <template id="tpl-experience">
        <div class="timeline-container">
            {
                experienceList.map((e) => (
                    <div class="timeline-item">
                        <div class="timeline-dot" />
                        <div class="timeline-content">
                            <h4 class="timeline-role">{e.role}</h4>
                            <span class="timeline-company text-cyan font-mono">
                                {e.company}
                            </span>
                            <span class="timeline-date text-muted">
                                {e.date}
                            </span>
                            <p class="timeline-desc text-muted">{e.desc}</p>
                        </div>
                    </div>
                ))
            }
        </div>
    </template>

    <template id="tpl-projects">
        <div class="plist-container">
            {
                projectsList.map((p, i) => (
                    <a
                        href={
                            p.links.live !== "#" ? p.links.live : p.links.github
                        }
                        target="_blank"
                        rel="noopener noreferrer"
                        class="plist-item"
                        style="text-decoration: none;"
                    >
                        <span
                            class="plist-num font-mono"
                            style={`color: ${p.accent}`}
                        >
                            0{i + 1}
                        </span>
                        <div class="plist-text-single">
                            <span class="plist-name">{p.name}</span>
                        </div>
                        <ArrowRightIcon
                            class="plist-arrow"
                            width="14"
                            height="14"
                        />
                    </a>
                ))
            }
        </div>
    </template>
</section>

<Contact />

<style>
    /* ── Section ─────────────────────────────────────── */
    .bento-section {
        padding-bottom: 3rem;
    }

    /* ── Bento Grid ──────────────────────────────────── */
    .bento-grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        grid-auto-rows: auto;
        gap: 1rem;
    }

    /* ── Base Card ───────────────────────────────────── */
    .bento-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 1.5rem;
        position: relative;
        overflow: hidden;
        transition: border-color 0.3s var(--ease), transform 0.3s var(--ease),
            box-shadow 0.3s var(--ease);
    }

    .bento-card:hover {
        border-color: var(--border-glow);
        transform: translateY(-3px);
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4), 0 0 24px var(--green-glow);
    }

    .typing-cursor {
        animation: blink 1s step-end infinite;
        color: var(--green);
    }

    .bento-label {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        color: var(--text-muted);
        letter-spacing: 0.1em;
        margin-bottom: 1rem;
    }

    /* ── Grid placement ──────────────────────────────── */

    .bento-card--featured {
        grid-column: 1 / 9;
        grid-row: 1;
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 3rem;
        min-height: 240px;
        padding: 2.5rem;
        background: linear-gradient(
            135deg,
            rgba(0, 255, 136, 0.04),
            var(--surface)
        );
    }

    /* ── Portrait Interactions ── */
    .featured-portrait-container {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        overflow: hidden;
        flex-shrink: 0;
        position: relative;
        border: 2px solid var(--border-glow);
        box-shadow: 0 0 20px rgba(0, 255, 136, 0.1);
        cursor: crosshair;
        transition: transform 0.4s var(--ease-spring),
            box-shadow 0.4s var(--ease);
    }

    .featured-portrait {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: top;
        filter: grayscale(100%) contrast(1.1);
        transition: filter 0.5s var(--ease), transform 0.5s var(--ease);
    }

    .portrait-overlay {
        position: absolute;
        inset: 0;
        background: var(--green-glow);
        mix-blend-mode: overlay;
        opacity: 0.8;
        transition: opacity 0.5s var(--ease);
        z-index: 1;
    }

    /* Hover Effects */
    .featured-portrait-container:hover {
        transform: scale(1.05) rotate(-3deg);
        box-shadow: 0 0 30px rgba(0, 255, 136, 0.3),
            0 0 0 4px rgba(0, 255, 136, 0.1);
    }

    .featured-portrait-container:hover .featured-portrait {
        filter: grayscale(0%) contrast(1.05);
        transform: scale(1.1);
    }

    .featured-portrait-container:hover .portrait-overlay {
        opacity: 0;
    }

    /* ── Quote Content ── */
    .quote-content-large {
        display: flex;
        flex-direction: column;
        justify-content: center;
        flex: 1;
    }

    .quote-icon-large {
        color: var(--green);
        opacity: 0.2;
        margin-bottom: 0.75rem;
    }

    .quote-text-large {
        font-size: 1.5rem;
        line-height: 1.5;
        font-weight: 500;
        color: var(--text);
    }

    .bento-card--stats {
        grid-column: 9 / 13;
        grid-row: 1;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Row 2 */
    .bento-card--projects-list {
        grid-column: 1 / 7;
        grid-row: 2;
    }
    .bento-card--experience-list {
        grid-column: 7 / 13;
        grid-row: 2;
    }

    /* Row 3 */
    .bento-card--stack {
        grid-column: 1 / 5;
        grid-row: 3;
    }
    .bento-card--location {
        grid-column: 5 / 9;
        grid-row: 3;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }
    .bento-card--contrib {
        grid-column: 9 / 13;
        grid-row: 3;
    }

    /* Row 4 (Quote pushed down) */
    .bento-card--quote {
        grid-column: 1 / 13;
        grid-row: 4;
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        gap: 1.5rem;
        text-align: left;
        background: linear-gradient(135deg, var(--surface), #151520);
    }

    /* Row 5 */
    .bento-card--contact {
        grid-column: 1 / 13;
        grid-row: 5;
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 3rem;
        background: linear-gradient(135deg, #0f1520, var(--surface));
        border-color: rgba(0, 255, 136, 0.1);
    }

    /* Small project cards — shared styles only */
    .bento-card--project-sm {
        display: flex;
        flex-direction: column;
        gap: 0.625rem;
    }

    /* ── Stats ───────────────────────────────────────── */
    .stats-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        width: 100%;
    }

    .stat-item {
        text-align: center;
    }
    .stat-big {
        font-size: 2.25rem;
        font-weight: 800;
        line-height: 1;
        display: block;
    }
    .stat-lbl {
        font-size: 0.7rem;
        color: var(--text-muted);
        margin-top: 0.2rem;
    }
    .stat-sep {
        height: 1px;
        background: var(--border);
    }

    /* ── Stack Pills ─────────────────────────────────── */
    .stack-pills {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .pill-group {
        display: flex;
        align-items: center;
        gap: 0.375rem;
        flex-wrap: wrap;
    }

    .pill-cat {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        font-weight: 700;
        min-width: 68px;
        letter-spacing: 0.05em;
    }

    .pill {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 0.15rem 0.5rem;
        color: var(--text-muted);
        transition: all 0.2s;
    }

    .bento-card--stack:hover .pill {
        color: var(--text);
        border-color: rgba(255, 255, 255, 0.12);
    }

    /* ── Small Project Cards ─────────────────────────── */
    .proj-num {
        font-size: 1.5rem;
        font-weight: 800;
        opacity: 0.5;
        line-height: 1;
    }
    .proj-name {
        font-size: 1rem;
        font-weight: 700;
        color: var(--text);
    }
    .proj-desc {
        font-size: 0.8125rem;
        color: var(--text-muted);
        line-height: 1.55;
        flex: 1;
    }
    .proj-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.375rem;
        margin-top: auto;
    }

    /* ── Tags ────────────────────────────────────────── */
    .tag {
        font-family: var(--font-mono);
        font-size: 0.68rem;
        border-radius: 4px;
        padding: 0.2rem 0.5rem;
        border: 1px solid;
    }
    .tag--green {
        color: var(--green);
        border-color: rgba(0, 255, 136, 0.2);
        background: rgba(0, 255, 136, 0.06);
    }
    .tag--cyan {
        color: var(--cyan);
        border-color: rgba(0, 212, 255, 0.2);
        background: rgba(0, 212, 255, 0.06);
    }
    .tag--purple {
        color: var(--purple);
        border-color: rgba(139, 92, 246, 0.2);
        background: rgba(139, 92, 246, 0.06);
    }

    /* ── Quote ───────────────────────────────────────── */
    .quote-icon {
        font-size: 4rem;
        line-height: 1;
        color: var(--green);
        opacity: 0.15;
        font-family: Georgia, serif;
        margin-bottom: -1rem;
    }

    .quote-text {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text);
        line-height: 1.5;
        font-style: normal;
    }

    .quote-cite {
        font-size: 0.65rem;
        letter-spacing: 0.1em;
    }

    /* ── Wakatime Stats ───────────────────────────────── */
    .bento-card--contrib {
        grid-column: 9 / 13;
        grid-row: 3;
        display: flex;
        flex-direction: column;
    }

    .waka-content {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        margin-top: auto;
    }

    .waka-header {
        display: flex;
        flex-direction: column;
    }

    .waka-time {
        font-size: 1.5rem;
        font-weight: 700;
        line-height: 1;
        margin-bottom: 0.25rem;
    }

    .waka-subtitle {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .waka-langs {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .waka-lang-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 0.25rem;
        font-size: 0.75rem;
    }

    .waka-lang-name {
        font-weight: 500;
        color: var(--text);
    }

    .waka-progress-bg {
        height: 4px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 4px;
        overflow: hidden;
    }

    .waka-progress-bar {
        height: 100%;
        border-radius: 4px;
        box-shadow: 0 0 10px var(--green-glow);
    }

    /* ── Location Widget ─────────────────────────────── */
    .location-content {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-top: auto;
    }

    .location-icon-wrapper {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: rgba(0, 255, 136, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(0, 255, 136, 0.2);
        animation: float 3s ease-in-out infinite;
    }

    @keyframes float {
        0%,
        100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-5px);
        }
    }

    .location-city {
        font-size: 1.125rem;
        font-weight: 700;
        color: var(--text);
        display: block;
        margin-bottom: 0.25rem;
    }

    .location-time {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .time-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--green);
        animation: blink 1s step-end infinite;
    }

    /* ── Contact ─────────────────────────────────────── */
    .contact-big {
        font-size: 1.375rem;
        font-weight: 700;
        line-height: 1.2;
        margin: 0.5rem 0 1rem;
    }

    .contact-email {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--green);
        border: 1px solid var(--border-glow);
        border-radius: 6px;
        padding: 0.5rem 0.875rem;
        transition: all 0.2s;
        text-decoration: none;
        background: var(--green-glow);
    }

    .contact-email:hover {
        box-shadow: 0 0 20px var(--green-glow);
        color: var(--green);
    }

    .contact-socials-b {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: auto;
    }

    .social-b {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        font-family: var(--font-mono);
        font-size: 0.72rem;
        color: var(--text-muted);
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 0.375rem 0.625rem;
        text-decoration: none;
        transition: all 0.2s;
    }

    .social-b:hover {
        color: var(--green);
        border-color: var(--border-glow);
        background: var(--green-glow);
    }

    /* ── Footer ────────────────────────────────────────*/
    .bento-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.5rem 0 0.5rem;
        border-top: 1px solid var(--border);
        margin-top: 1rem;
    }

    /* ── Responsive ──────────────────────────────────── */
    @media (max-width: 1024px) {
        .bento-card {
            grid-row: auto !important;
        }
        .bento-card--featured {
            grid-column: 1 / -1;
        }
        .bento-card--stats {
            grid-column: 1 / -1;
        }
        .bento-card--stats .stats-list {
            flex-direction: row;
            justify-content: center;
            gap: 2rem;
        }
        .bento-card--stats .stat-sep {
            width: 1px;
            height: 40px;
        }
        .bento-card--projects-list {
            grid-column: 1 / 7;
        }
        .bento-card--experience-list {
            grid-column: 7 / 13;
        }
        .bento-card--stack {
            grid-column: 1 / -1;
        }
