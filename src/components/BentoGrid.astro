---
import userPhoto from "../assets/images/user-photo.JPG";
---

<!--
  BENTO GRID — Section 2
  Single responsive CSS grid mixing all content:
  projects, stack, experience, contact, stats, quote
-->
<section class="section bento-section" id="bento">
    <div class="container">
        <div class="bento-grid">
            <!-- ── CARD 1: Developer Quote & Portrait (wide) ── -->
            <article class="bento-card bento-card--featured" id="projects">
                <div class="featured-portrait-container">
                    <img
                        src={userPhoto.src}
                        alt="Ismail Alam"
                        class="featured-portrait"
                    />
                    <div class="portrait-overlay"></div>
                </div>

                <div class="quote-content-large">
                    <svg
                        class="quote-icon-large"
                        width="40"
                        height="40"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path
                            d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"
                        ></path>
                        <path
                            d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"
                        ></path>
                    </svg>
                    <div class="quote-text-large">
                        <span
                            id="dynamic-typing-text"
                            class="text-green font-mono"></span><span
                            class="typing-cursor">_</span
                        >
                    </div>
                </div>
            </article>

            <!-- ── CARD 2: Stats ── -->
            <div class="bento-card bento-card--stats">
                <div class="stats-list">
                    <div class="stat-item">
                        <span class="stat-big text-green font-mono">3+</span>
                        <span class="stat-lbl">Years Experience</span>
                    </div>
                    <div class="stat-sep"></div>
                    <div class="stat-item">
                        <span class="stat-big text-cyan font-mono">20+</span>
                        <span class="stat-lbl">Projects Shipped</span>
                    </div>
                    <div class="stat-sep"></div>
                    <div class="stat-item">
                        <span class="stat-big text-purple font-mono">5</span>
                        <span class="stat-lbl">OSS Contributions</span>
                    </div>
                </div>
            </div>

            <!-- ── CARD 3: Tech Stack ── -->
            <div class="bento-card bento-card--stack" id="stack">
                <div class="bento-label">// tech stack</div>
                <div class="stack-pills">
                    <div class="pill-group">
                        <span class="pill-cat text-green">Backend</span>
                        <span class="pill">Go</span>
                        <span class="pill">Node.js</span>
                        <span class="pill">Laravel</span>
                        <span class="pill">GraphQL</span>
                    </div>
                    <div class="pill-group">
                        <span class="pill-cat text-cyan">Frontend</span>
                        <span class="pill">React</span>
                        <span class="pill">Next.js</span>
                        <span class="pill">Astro</span>
                        <span class="pill">TypeScript</span>
                    </div>
                    <div class="pill-group">
                        <span class="pill-cat text-purple">Mobile</span>
                        <span class="pill">Flutter</span>
                        <span class="pill">Dart</span>
                    </div>
                    <div class="pill-group">
                        <span class="pill-cat" style="color:var(--yellow)"
                            >DevOps</span
                        >
                        <span class="pill">Docker</span>
                        <span class="pill">Linux</span>
                        <span class="pill">CI/CD</span>
                    </div>
                </div>
            </div>

            <!-- ── CARD 4a: Project 02 (row 2) ── -->
            <div class="bento-card bento-card--project-sm bento-card--proj2">
                <span class="proj-num font-mono text-cyan">02</span>
                <h4 class="proj-name">Neural Engine Core</h4>
                <p class="proj-desc">
                    Distributed task engine with priority queues & real-time
                    observability.
                </p>
                <div class="proj-tags">
                    <span class="tag tag--cyan">TypeScript</span>
                    <span class="tag tag--cyan">Redis</span>
                    <span class="tag tag--cyan">Docker</span>
                </div>
            </div>

            <div class="bento-card bento-card--project-sm bento-card--proj3">
                <span class="proj-num font-mono text-purple">03</span>
                <h4 class="proj-name">Distributed Ledger</h4>
                <p class="proj-desc">
                    Microservice accounting ledger with multi-currency & CQRS
                    architecture.
                </p>
                <div class="proj-tags">
                    <span class="tag tag--purple">Go</span>
                    <span class="tag tag--purple">gRPC</span>
                    <span class="tag tag--purple">PostgreSQL</span>
                </div>
            </div>

            <!-- ── CARD 5: Quote / Philosophy ── -->
            <div class="bento-card bento-card--quote">
                <div class="quote-icon">"</div>
                <blockquote class="quote-text">
                    Make it work, make it<br />
                    <em class="text-green">right</em>, make it
                    <em class="text-cyan">fast</em>.
                </blockquote>
                <cite class="quote-cite font-mono text-muted"
                    >— engineering philosophy</cite
                >
            </div>

            <!-- ── CARD 6: Contributions ── -->
            <div class="bento-card bento-card--contrib" id="experience">
                <div class="bento-label">// open source</div>
                <div class="contrib-list">
                    <div class="contrib-item">
                        <span class="contrib-icon">⚛️</span>
                        <div>
                            <p class="contrib-role">React Contributor</p>
                            <p class="contrib-desc">
                                Bug fixes in core components
                            </p>
                        </div>
                    </div>
                    <div class="contrib-item">
                        <span class="contrib-icon">🛠️</span>
                        <div>
                            <p class="contrib-role">CLI Tools Developer</p>
                            <p class="contrib-desc">
                                Custom shell utilities for engineers
                            </p>
                        </div>
                    </div>
                    <div class="contrib-item">
                        <span class="contrib-icon">✍️</span>
                        <div>
                            <p class="contrib-role">Tech Blogger</p>
                            <p class="contrib-desc">
                                System design & architecture writing
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── CARD 7: More Projects ── -->
            <div class="bento-card bento-card--more-projects">
                <div class="bento-label">// more projects</div>
                <div class="more-list">
                    <a href="#" class="more-item">
                        <span class="more-num font-mono">04</span>
                        <span class="more-name">Analytics Dashboard</span>
                        <span class="more-stack text-muted font-mono"
                            >React · Next.js</span
                        >
                        <svg
                            class="more-arrow"
                            width="12"
                            height="12"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            ><path d="M5 12h14M12 5l7 7-7 7"></path>
                        </svg>
                    </a>
                    <a href="#" class="more-item">
                        <span class="more-num font-mono">05</span>
                        <span class="more-name">Social Mobile UI</span>
                        <span class="more-stack text-muted font-mono"
                            >Flutter · Firebase</span
                        >
                        <svg
                            class="more-arrow"
                            width="12"
                            height="12"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            ><path d="M5 12h14M12 5l7 7-7 7"></path>
                        </svg>
                    </a>
                </div>
            </div>

            <!-- ── CARD 8: Contact (wide) ── -->
            <div class="bento-card bento-card--contact" id="contact">
                <div class="contact-left-b">
                    <div class="bento-label">// let's build together</div>
                    <h3 class="contact-big">
                        Available for<br /><span class="text-green"
                            >new projects</span
                        >
                    </h3>
                    <a href="mailto:mail@itzmail.dev" class="contact-email">
                        <svg
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            ><rect width="20" height="16" x="2" y="4" rx="2"
                            ></rect><path
                                d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"
                            ></path>
                        </svg>
                        mail@itzmail.dev
                    </a>
                </div>
                <div class="contact-socials-b">
                    <a
                        href="https://github.com/ismailalam"
                        class="social-b"
                        target="_blank"
                        rel="noopener"
                    >
                        <svg
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            ><path
                                d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
                            ></path>
                        </svg>
                        GitHub
                    </a>
                    <a
                        href="https://linkedin.com/in/ismailalam"
                        class="social-b"
                        target="_blank"
                        rel="noopener"
                    >
                        <svg
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            ><path
                                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                            ></path>
                        </svg>
                        LinkedIn
                    </a>
                    <a
                        href="https://twitter.com/itzmail_dev"
                        class="social-b"
                        target="_blank"
                        rel="noopener"
                    >
                        <svg
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            ><path
                                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                            ></path>
                        </svg>
                        Twitter
                    </a>
                    <a
                        href="https://dribbble.com/itzmail"
                        class="social-b"
                        target="_blank"
                        rel="noopener"
                    >
                        <svg
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            ><path
                                d="M12 0C5.374 0 0 5.373 0 12c0 6.628 5.374 12 12 12 6.627 0 12-5.372 12-12 0-6.627-5.373-12-12-12zm7.369 5.424a10.167 10.167 0 012.207 5.686 29.81 29.81 0 00-5.97-.8c-.264-.622-.529-1.24-.816-1.853a29.736 29.736 0 004.579-3.033zm-1.433-1.474a27.886 27.886 0 01-4.255 2.802A28.038 28.038 0 0010 1.929a10.165 10.165 0 017.936 2.021zM8.261 2.539a26.252 26.252 0 013.716 4.664 27.93 27.93 0 01-6.824 1.056H1.832A10.182 10.182 0 018.261 2.54zM1.773 10.022h.119c2.603 0 5.117-.38 7.494-1.11.224.448.442.9.648 1.357C6.65 11.492 3.866 13.826 1.948 16.74A10.138 10.138 0 011.773 10.02zm1.79 8.045C5.37 15.6 8.006 13.4 11.37 12.26c.862 2.248 1.52 4.557 1.97 6.932A10.155 10.155 0 012.12 17.67a10.22 10.22 0 01-.557-.604zm9.898 4.25c-.388-2.2-1-4.339-1.807-6.42 1.926-.302 4.012-.09 6.137.706a10.2 10.2 0 01-4.33 5.714zm5.828-7.186c-2.4-.927-4.752-1.175-6.934-.76a27.61 27.61 0 00-.624-1.47 29.614 29.614 0 006.545.69c0 .18 0 .36-.01.54h.023z"
                            ></path>
                        </svg>
                        Dribbble
                    </a>
                </div>
            </div>
        </div><!-- /bento-grid -->
    </div>

    <!-- Footer -->
    <div class="container">
        <footer class="bento-footer">
            <span class="font-mono text-muted" style="font-size:.8rem">
                <span class="text-green">[</span>itzmail<span class="text-cyan"
                    >.</span
                >dev<span class="text-green">]</span>
            </span>
            <p class="font-mono text-muted" style="font-size:.75rem">
                © 2024 Ismail Alam — Built with <span class="text-green"
                    >Astro</span
                > &amp; ☕
            </p>
        </footer>
    </div>
</section>

<style>
    /* ── Section ─────────────────────────────────────── */
    .bento-section {
        padding-bottom: 3rem;
    }

    /* ── Bento Grid ──────────────────────────────────── */
    .bento-grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        grid-auto-rows: auto;
        gap: 1rem;
    }

    /* ── Base Card ───────────────────────────────────── */
    .bento-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 1.5rem;
        position: relative;
        overflow: hidden;
        transition: border-color 0.3s var(--ease), transform 0.3s var(--ease),
            box-shadow 0.3s var(--ease);
    }

    .bento-card:hover {
        border-color: var(--border-glow);
        transform: translateY(-3px);
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4), 0 0 24px var(--green-glow);
    }

    .typing-cursor {
        animation: blink 1s step-end infinite;
        color: var(--green);
    }

    .bento-label {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        color: var(--text-muted);
        letter-spacing: 0.1em;
        margin-bottom: 1rem;
    }

    /* ── Grid placement ──────────────────────────────── */

    .bento-card--featured {
        grid-column: 1 / 9;
        grid-row: 1;
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 3rem;
        min-height: 240px;
        padding: 2.5rem;
        background: linear-gradient(
            135deg,
            rgba(0, 255, 136, 0.04),
            var(--surface)
        );
    }

    /* ── Portrait Interactions ── */
    .featured-portrait-container {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        overflow: hidden;
        flex-shrink: 0;
        position: relative;
        border: 2px solid var(--border-glow);
        box-shadow: 0 0 20px rgba(0, 255, 136, 0.1);
        cursor: crosshair;
        transition: transform 0.4s var(--ease-spring),
            box-shadow 0.4s var(--ease);
    }

    .featured-portrait {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: top;
        filter: grayscale(100%) contrast(1.1);
        transition: filter 0.5s var(--ease), transform 0.5s var(--ease);
    }

    .portrait-overlay {
        position: absolute;
        inset: 0;
        background: var(--green-glow);
        mix-blend-mode: overlay;
        opacity: 0.8;
        transition: opacity 0.5s var(--ease);
        z-index: 1;
    }

    /* Hover Effects */
    .featured-portrait-container:hover {
        transform: scale(1.05) rotate(-3deg);
        box-shadow: 0 0 30px rgba(0, 255, 136, 0.3),
            0 0 0 4px rgba(0, 255, 136, 0.1);
    }

    .featured-portrait-container:hover .featured-portrait {
        filter: grayscale(0%) contrast(1.05);
        transform: scale(1.1);
    }

    .featured-portrait-container:hover .portrait-overlay {
        opacity: 0;
    }

    /* ── Quote Content ── */
    .quote-content-large {
        display: flex;
        flex-direction: column;
        justify-content: center;
        flex: 1;
    }

    .quote-icon-large {
        color: var(--green);
        opacity: 0.2;
        margin-bottom: 0.75rem;
    }

    .quote-text-large {
        font-size: 1.5rem;
        line-height: 1.5;
        font-weight: 500;
        color: var(--text);
    }

    .bento-card--stats {
        grid-column: 9 / 13;
        grid-row: 1;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Row 2 */
    .bento-card--stack {
        grid-column: 1 / 6;
        grid-row: 2;
    }

    /* Small project cards — shared styles only */
    .bento-card--project-sm {
        display: flex;
        flex-direction: column;
        gap: 0.625rem;
    }

    .bento-card--proj2 {
        grid-column: 6 / 10;
        grid-row: 2;
    }

    .bento-card--quote {
        grid-column: 10 / 13;
        grid-row: 2;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 0.5rem;
        text-align: center;
        background: linear-gradient(135deg, var(--surface), #151520);
    }

    /* Row 3 */
    .bento-card--proj3 {
        grid-column: 1 / 5;
        grid-row: 3;
    }

    .bento-card--contrib {
        grid-column: 5 / 9;
        grid-row: 3;
    }

    .bento-card--more-projects {
        grid-column: 9 / 13;
        grid-row: 3;
    }

    /* Row 4 */
    .bento-card--contact {
        grid-column: 1 / 13;
        grid-row: 4;
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 3rem;
        background: linear-gradient(135deg, #0f1520, var(--surface));
        border-color: rgba(0, 255, 136, 0.1);
    }

    /* ── Stats ───────────────────────────────────────── */
    .stats-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        width: 100%;
    }

    .stat-item {
        text-align: center;
    }
    .stat-big {
        font-size: 2.25rem;
        font-weight: 800;
        line-height: 1;
        display: block;
    }
    .stat-lbl {
        font-size: 0.7rem;
        color: var(--text-muted);
        margin-top: 0.2rem;
    }
    .stat-sep {
        height: 1px;
        background: var(--border);
    }

    /* ── Stack Pills ─────────────────────────────────── */
    .stack-pills {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .pill-group {
        display: flex;
        align-items: center;
        gap: 0.375rem;
        flex-wrap: wrap;
    }

    .pill-cat {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        font-weight: 700;
        min-width: 68px;
        letter-spacing: 0.05em;
    }

    .pill {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 0.15rem 0.5rem;
        color: var(--text-muted);
        transition: all 0.2s;
    }

    .bento-card--stack:hover .pill {
        color: var(--text);
        border-color: rgba(255, 255, 255, 0.12);
    }

    /* ── Small Project Cards ─────────────────────────── */
    .proj-num {
        font-size: 1.5rem;
        font-weight: 800;
        opacity: 0.5;
        line-height: 1;
    }
    .proj-name {
        font-size: 1rem;
        font-weight: 700;
        color: var(--text);
    }
    .proj-desc {
        font-size: 0.8125rem;
        color: var(--text-muted);
        line-height: 1.55;
        flex: 1;
    }
    .proj-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.375rem;
        margin-top: auto;
    }

    /* ── Tags ────────────────────────────────────────── */
    .tag {
        font-family: var(--font-mono);
        font-size: 0.68rem;
        border-radius: 4px;
        padding: 0.2rem 0.5rem;
        border: 1px solid;
    }
    .tag--green {
        color: var(--green);
        border-color: rgba(0, 255, 136, 0.2);
        background: rgba(0, 255, 136, 0.06);
    }
    .tag--cyan {
        color: var(--cyan);
        border-color: rgba(0, 212, 255, 0.2);
        background: rgba(0, 212, 255, 0.06);
    }
    .tag--purple {
        color: var(--purple);
        border-color: rgba(139, 92, 246, 0.2);
        background: rgba(139, 92, 246, 0.06);
    }

    /* ── Quote ───────────────────────────────────────── */
    .quote-icon {
        font-size: 4rem;
        line-height: 1;
        color: var(--green);
        opacity: 0.15;
        font-family: Georgia, serif;
        margin-bottom: -1rem;
    }

    .quote-text {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text);
        line-height: 1.5;
        font-style: normal;
    }

    .quote-cite {
        font-size: 0.65rem;
        letter-spacing: 0.1em;
    }

    /* ── Contributions ───────────────────────────────── */
    .contrib-list {
        display: flex;
        flex-direction: column;
        gap: 0.875rem;
    }

    .contrib-item {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        padding: 0.625rem;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--border);
